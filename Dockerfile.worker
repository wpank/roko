# Roko worker image — runs `roko worker`, which decodes ROKO_TEMPLATE_JSON from
# the environment and serves /health, /task, /status on $PORT (default 8080).
#
# Deployed per-agent by the control plane's railway-api backend, which pulls
# this image from GHCR and injects ROKO_TEMPLATE_JSON, ROKO_CONTROL_PLANE_URL,
# ROKO_DEPLOYMENT_ID, ANTHROPIC_API_KEY, and PORT (Railway-injected).

FROM rust:1.91-bookworm AS builder
WORKDIR /app
COPY . .
RUN cargo build --release -p roko-cli

FROM debian:bookworm-slim AS runtime
RUN apt-get update && apt-get install -y --no-install-recommends \
        ca-certificates \
        libssl3 \
        git \
    && rm -rf /var/lib/apt/lists/*

COPY --from=builder /app/target/release/roko /usr/local/bin/roko

WORKDIR /workspace

ENTRYPOINT ["/usr/local/bin/roko"]
CMD ["worker"]
EXPOSE 8080
