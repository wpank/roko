# Required for Anthropic models (claude-sonnet, claude-haiku)
ANTHROPIC_API_KEY=

# Required for Moonshot/Kimi models (kimi-k2.5)
MOONSHOT_API_KEY=

# Required for Z.AI/GLM models (glm-5.1)
ZAI_API_KEY=

# Ollama runs locally — no API key needed
# Make sure ollama is running: ollama serve
# Pull models: ollama pull llama3.2 && ollama pull gemma4
