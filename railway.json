{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile",
    "watchPatterns": [
      "apps/**",
      "crates/**",
      "demo/demo-app/**",
      "docker/start-railway.sh",
      "roko.toml",
      "Dockerfile",
      "Cargo.toml",
      "Cargo.lock"
    ]
  },
  "deploy": {
    "healthcheckPath": "/health",
    "healthcheckTimeout": 300,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
