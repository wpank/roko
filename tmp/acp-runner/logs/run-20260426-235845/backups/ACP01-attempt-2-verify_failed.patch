+}
+
+impl SessionState {
+    /// Creates a new ACP session scaffold with generated id and default options.
+    #[must_use]
+    pub fn new(
+        session_name: Option<String>,
+        client_capabilities: Option<ClientCapabilities>,
+        mcp_servers: Vec<McpServerConfig>,
+    ) -> Self {
+        Self {
+            session_id: format!("{SESSION_ID_PREFIX}{}", Uuid::new_v4()),
+            session_name,
+            created_at: Utc::now(),
+            client_capabilities,
+            mcp_servers,
+            config_options: default_config_options(),
+        }
+    }
+
+    /// Returns ACP session metadata for `session/list`.
+    #[must_use]
+    pub fn info(&self) -> SessionInfo {
+        SessionInfo {
