+#[cfg(test)]
+mod tests {
+    use super::*;
+    use serde_json::json;
+
+    #[test]
+    fn json_rpc_request_round_trips() {
+        let request = JsonRpcRequest {
+            jsonrpc: "2.0".to_owned(),
+            id: JsonRpcId::Number(1),
+            method: "initialize".to_owned(),
+            params: Some(json!({
+                "protocolVersion": ACP_PROTOCOL_VERSION,
+            })),
+        };
+
+        let value = serde_json::to_value(&request).expect("request should serialize");
+        assert_eq!(
+            value,
+            json!({
+                "jsonrpc": "2.0",
+                "id": 1,
+                "method": "initialize",
+                "params": {
+                    "protocolVersion": 1
+                }
+            })
+        );
+
+        let decoded: JsonRpcRequest =
+            serde_json::from_value(value).expect("request should deserialize");
+        match decoded.id {
+            JsonRpcId::Number(id) => assert_eq!(id, 1),
+            JsonRpcId::String(id) => panic!("unexpected string id: {id}"),
+        }
+        assert_eq!(decoded.jsonrpc, "2.0");
+        assert_eq!(decoded.method, "initialize");
+        assert_eq!(
+            decoded.params.expect("params should be present"),
+            json!({ "protocolVersion": 1 })
+        );
+    }
+
+    #[test]
+    fn session_update_agent_message_chunk_round_trips() {
+        let update = SessionUpdate::AgentMessageChunk {
+            content: ContentBlock::Text {
+                text: "hello".to_owned(),
+            },
+            _meta: None,
+        };
+
+        let value = serde_json::to_value(&update).expect("update should serialize");
+        assert_eq!(
+            value,
+            json!({
+                "sessionUpdate": "agent_message_chunk",
+                "content": {
+                    "type": "text",
+                    "text": "hello"
+                }
+            })
+        );
+
+        let decoded: SessionUpdate =
+            serde_json::from_value(value).expect("update should deserialize");
+        match decoded {
+            SessionUpdate::AgentMessageChunk { content, .. } => match content {
+                ContentBlock::Text { text } => assert_eq!(text, "hello"),
+                other => panic!("unexpected content block: {other:?}"),
+            },
+            other => panic!("unexpected session update: {other:?}"),
+        }
+    }
+
+    #[test]
+    fn config_option_round_trips() {
+        let option = ConfigOption {
+            id: "approval_policy".to_owned(),
+            name: "Approval Policy".to_owned(),
+            option_type: ConfigOptionType::Select,
+            category: "permissions".to_owned(),
+            current_value: json!("on-request"),
+            description: Some("Controls when the agent asks for approval.".to_owned()),
+            options: Some(vec![ConfigOptionValue {
+                value: "on-request".to_owned(),
+                name: "On Request".to_owned(),
+                description: None,
+            }]),
+        };
+
+        let value = serde_json::to_value(&option).expect("config option should serialize");
+        assert_eq!(
+            value,
+            json!({
+                "id": "approval_policy",
+                "name": "Approval Policy",
+                "type": "select",
+                "category": "permissions",
+                "currentValue": "on-request",
+                "description": "Controls when the agent asks for approval.",
+                "options": [
+                    {
+                        "value": "on-request",
+                        "name": "On Request"
+                    }
+                ]
+            })
+        );
+
+        let decoded: ConfigOption =
+            serde_json::from_value(value).expect("config option should deserialize");
+        assert_eq!(decoded.id, "approval_policy");
+        assert_eq!(decoded.name, "Approval Policy");
+        assert!(matches!(decoded.option_type, ConfigOptionType::Select));
+        assert_eq!(decoded.category, "permissions");
+        assert_eq!(decoded.current_value, json!("on-request"));
+        assert_eq!(
+            decoded.description.as_deref(),
+            Some("Controls when the agent asks for approval.")
+        );
+        assert_eq!(decoded.options.expect("options should be present").len(), 1);
+    }
+}
