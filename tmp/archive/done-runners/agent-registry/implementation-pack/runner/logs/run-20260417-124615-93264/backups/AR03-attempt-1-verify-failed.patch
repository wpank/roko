+pub fn spawn_roko_agent_serve_on_random_port(workdir: &Path, agent_id: &str) -> ServeHandle {
+    let port = pick_unused_port();
+    let bind = format!("127.0.0.1:{port}");
+    let base_url = format!("http://{bind}");
+    let bin = cargo_bin("roko");
+    let child = ProcessCommand::new(bin)
+        .current_dir(workdir)
+        .arg("agent")
+        .arg("serve")
+        .arg("--agent-id")
+        .arg(agent_id)
+        .arg("--bind")
+        .arg(&bind)
+        .stdout(Stdio::null())
+        .stderr(Stdio::null())
+        .spawn()
+        .unwrap_or_else(|err| panic!("spawn roko agent serve: {err}"));
+
+    ServeHandle { base_url, child }
+}
