+// ---------------------------------------------------------------------------
+// Segment parsing + cached render
+// ---------------------------------------------------------------------------
+
+mod segment {
+    use std::collections::HashMap;
+    use std::sync::{Mutex, OnceLock};
+
+    use ratatui::style::{Modifier, Style};
+    use ratatui::text::{Line, Span};
+
+    use crate::tui::ansi::parse_ansi_line;
+    use crate::tui::dashboard::Theme;
+    use crate::tui::widgets::rosedust::MoriTheme;
+
+    /// Semantic segment types for agent output.
+    #[derive(Debug, Clone, Copy, PartialEq, Eq)]
+    pub(crate) enum SegmentKind {
+        Thinking,
+        Heading,
+        ToolUse,
+        Code,
+        Success,
+        Error,
+        Blank,
+        TurnMarker,
+    }
+
+    /// A consecutive run of agent output lines with the same semantic type.
+    #[derive(Debug, Clone)]
+    pub(crate) struct SegmentGroup {
+        pub kind: SegmentKind,
+        pub lines: Vec<String>,
+    }
+
+    /// Cached styled render for one agent output stream.
+    #[derive(Debug, Clone)]
+    pub(crate) struct CachedRender {
+        pub last_len: usize,
+        pub groups: Vec<SegmentGroup>,
+        pub styled_lines: Vec<Line<'static>>,
+    }
+
+    static OUTPUT_RENDER_CACHE: OnceLock<Mutex<HashMap<String, CachedRender>>> = OnceLock::new();
+
+    fn cache() -> &'static Mutex<HashMap<String, CachedRender>> {
+        OUTPUT_RENDER_CACHE.get_or_init(|| Mutex::new(HashMap::new()))
+    }
+
+    pub(crate) fn cached_render(agent_id: &str, lines: &[String], theme: &Theme) -> CachedRender {
+        let last_len = output_len(lines);
+
+        if let Some(cached) = cache()
+            .lock()
+            .expect("agent output render cache poisoned")
+            .get(agent_id)
+            .filter(|cached| cached.last_len == last_len)
+            .cloned()
+        {
+            return cached;
+        }
+
+        let groups = group_segments(&preprocess_lines(lines));
+        let styled_lines = render_groups(&groups, theme);
+        let rendered = CachedRender {
+            last_len,
+            groups,
+            styled_lines,
+        };
+
+        cache()
+            .lock()
+            .expect("agent output render cache poisoned")
+            .insert(agent_id.to_string(), rendered.clone());
+        rendered
+    }
+
+    fn output_len(lines: &[String]) -> usize {
+        lines.iter().map(|line| line.len()).sum::<usize>() + lines.len().saturating_sub(1)
+    }
+
+    pub(crate) fn preprocess_lines(lines: &[String]) -> Vec<String> {
+        let mut out = Vec::new();
+        for line in lines {
+            let replaced = line
+                .replace("Now ", "\nNow ")
+                .replace("Let ", "\nLet ")
+                .replace("I'll ", "\nI'll ");
+
+            let fragments = replaced.split('\n').filter(|fragment| {
+                !fragment.is_empty() || line.trim().is_empty()
+            });
+
+            for fragment in fragments {
+                for split in split_long_line(fragment) {
+                    out.push(split);
+                }
+            }
+        }
+        out
+    }
+
+    pub(crate) fn split_long_line(line: &str) -> Vec<String> {
+        if line.len() <= 120 {
+            return vec![line.to_string()];
+        }
+
+        let boundary = line
+            .match_indices(". ")
+            .map(|(idx, _)| idx + 1)
+            .filter(|idx| *idx <= 120)
+            .last()
+            .or_else(|| {
+                line.match_indices(". ")
+                    .map(|(idx, _)| idx + 1)
+                    .find(|idx| *idx > 120)
+            });
+
+        let split_at = boundary.unwrap_or(120.min(line.len()));
+        if split_at >= line.len() {
+            return vec![line.to_string()];
+        }
+
+        let (head, tail) = line.split_at(split_at);
+        let mut parts = vec![head.trim_end().to_string()];
+        let tail = tail.trim_start();
+        if !tail.is_empty() {
+            parts.extend(split_long_line(tail));
+        }
+        parts
+    }
+
+    pub(crate) fn group_segments(lines: &[String]) -> Vec<SegmentGroup> {
+        let mut groups = Vec::new();
+        let mut current_kind: Option<SegmentKind> = None;
+        let mut current_lines: Vec<String> = Vec::new();
+        let mut in_code_block = false;
+        let mut prev_blank = true;
+
+        for line in lines {
+            let kind = classify_line(line, in_code_block, prev_blank);
+            let is_fence = line.trim_start().starts_with("```");
+
+            match current_kind {
+                Some(current) if current == kind => current_lines.push(line.clone()),
+                Some(current) => {
+                    groups.push(SegmentGroup {
+                        kind: current,
+                        lines: std::mem::take(&mut current_lines),
+                    });
+                    current_kind = Some(kind);
+                    current_lines.push(line.clone());
+                }
+                None => {
+                    current_kind = Some(kind);
+                    current_lines.push(line.clone());
+                }
+            }
+
+            prev_blank = matches!(kind, SegmentKind::Blank);
+            if is_fence {
+                in_code_block = !in_code_block;
+            }
+        }
+
+        if let Some(kind) = current_kind {
+            groups.push(SegmentGroup {
+                kind,
+                lines: current_lines,
+            });
+        }
+
+        groups
+    }
+
+    fn classify_line(line: &str, in_code_block: bool, prev_blank: bool) -> SegmentKind {
+        let trimmed = line.trim_start();
+        if line.trim().is_empty() {
+            return SegmentKind::Blank;
+        }
+        if trimmed.starts_with("```") {
+            return SegmentKind::Code;
+        }
+        if in_code_block {
+            return SegmentKind::Code;
+        }
+        if trimmed.starts_with("# ")
+            || trimmed.starts_with("## ")
+            || trimmed.starts_with("### ")
+        {
+            return SegmentKind::Heading;
+        }
+        if trimmed.starts_with("▸ ")
+            || trimmed.starts_with("> ")
+            || trimmed.starts_with("$ ")
+            || trimmed.starts_with("Running ")
+            || trimmed.starts_with("Reading ")
+            || trimmed.starts_with("Writing ")
+            || trimmed.starts_with("Editing ")
+            || trimmed.starts_with("Created ")
+        {
+            return SegmentKind::ToolUse;
+        }
+        if prev_blank && line.starts_with("    ") {
+            return SegmentKind::Code;
+        }
+        if line.contains('✓') || line.contains("PASS") || line.contains("APPROVE") {
+            return SegmentKind::Success;
+        }
+        if line.contains("ERROR") || line.contains("FAILED") || line.contains("error[") || trimmed.starts_with("error") {
+            return SegmentKind::Error;
+        }
+        if trimmed.starts_with("────") {
+            return SegmentKind::TurnMarker;
+        }
+        SegmentKind::Thinking
+    }
+
+    fn render_groups(groups: &[SegmentGroup], theme: &Theme) -> Vec<Line<'static>> {
+        let mut lines = Vec::new();
+        for group in groups {
+            if group.kind != SegmentKind::Blank {
+                lines.push(render_group_header(group.kind, theme));
+            }
+            for line in &group.lines {
+                lines.push(render_segment_line(line, group.kind, theme));
+            }
+        }
+        lines
+    }
+
+    fn render_group_header(kind: SegmentKind, theme: &Theme) -> Line<'static> {
+        let label = match kind {
+            SegmentKind::Thinking => "thinking",
+            SegmentKind::Heading => "heading",
+            SegmentKind::ToolUse => "tool use",
+            SegmentKind::Code => "code",
+            SegmentKind::Success => "success",
+            SegmentKind::Error => "error",
+            SegmentKind::Blank => "blank",
+            SegmentKind::TurnMarker => "turn marker",
+        };
+
+        Line::from(vec![
+            Span::styled("  ", Style::default()),
+            Span::styled(
+                format!("[{label}]"),
+                Style::default()
+                    .fg(theme.muted)
+                    .add_modifier(Modifier::ITALIC),
+            ),
+        ])
+    }
+
+    fn render_segment_line(line: &str, kind: SegmentKind, theme: &Theme) -> Line<'static> {
+        let base_style = segment_style(kind, theme);
+        let mut spans = vec![Span::styled(" ", base_style)];
+        if line.is_empty() {
+            spans.push(Span::styled(String::new(), base_style));
+            return Line::from(spans);
+        }
+
+        spans.extend(
+            parse_ansi_line(line)
+                .into_iter()
+                .map(|span| Span::styled(span.content.to_string(), base_style.patch(span.style))),
+        );
+        Line::from(spans)
+    }
+
+    fn segment_style(kind: SegmentKind, theme: &Theme) -> Style {
+        match kind {
+            SegmentKind::Thinking => Style::default().fg(theme.muted),
+            SegmentKind::Heading => Style::default()
+                .fg(theme.accent)
+                .add_modifier(Modifier::BOLD),
+            SegmentKind::ToolUse => Style::default().fg(theme.info),
+            SegmentKind::Code => Style::default()
+                .fg(MoriTheme::SAGE)
+                .bg(MoriTheme::BG_SECONDARY),
+            SegmentKind::Success => Style::default()
+                .fg(theme.success)
+                .add_modifier(Modifier::BOLD),
+            SegmentKind::Error => Style::default()
+                .fg(theme.danger)
+                .add_modifier(Modifier::BOLD),
+            SegmentKind::Blank => Style::default().fg(theme.muted),
+            SegmentKind::TurnMarker => Style::default()
+                .fg(theme.muted)
+                .add_modifier(Modifier::ITALIC),
+        }
+    }
+
+    #[cfg(test)]
+    mod tests {
+        use super::*;
+        use crate::tui::dashboard::Theme;
+
+        fn theme() -> Theme {
+            Theme::dark()
+        }
+
+        #[test]
+        fn classifies_and_groups_semantic_lines() {
+            let lines = vec![
+                "# heading".to_string(),
+                "Running tool".to_string(),
+                "plain text".to_string(),
+                "plain follow-up".to_string(),
+                "✓ done".to_string(),
+            ];
+            let groups = group_segments(&lines);
+            assert_eq!(groups.len(), 4);
+            assert_eq!(groups[0].kind, SegmentKind::Heading);
+            assert_eq!(groups[1].kind, SegmentKind::ToolUse);
+            assert_eq!(groups[2].kind, SegmentKind::Thinking);
+            assert_eq!(groups[2].lines.len(), 2);
+            assert_eq!(groups[3].kind, SegmentKind::Success);
+        }
+
+        #[test]
+        fn preprocesses_paragraph_breaks_before_common_phrases() {
+            let lines = vec!["We were here. Now go. Let us move. I'll stay.".to_string()];
+            let preprocessed = preprocess_lines(&lines);
+            assert_eq!(
+                preprocessed,
+                vec![
+                    "We were here.".to_string(),
+                    "Now go.".to_string(),
+                    "Let us move.".to_string(),
+                    "I'll stay.".to_string(),
+                ]
+            );
+        }
+
+        #[test]
+        fn splits_long_lines_at_sentence_boundaries() {
+            let long = format!(
+                "{}. {}. {}",
+                "a".repeat(70),
+                "b".repeat(70),
+                "c".repeat(70)
+            );
+            let split = split_long_line(&long);
+            assert!(split.len() >= 2);
+            assert!(split.iter().all(|part| !part.is_empty()));
+        }
+
+        #[test]
+        fn caches_by_output_length() {
+            let mut lines = vec!["plain text".to_string()];
+            let first = cached_render("agent-1", &lines, &theme());
+            assert_eq!(first.last_len, 10);
+
+            lines[0] = "changed".to_string();
+            let second = cached_render("agent-1", &lines, &theme());
+            assert_eq!(second.last_len, 7);
+        }
+    }
+}
