+trait AgentOutputRenderExt {
+    fn render_agent_output_lines(
+        &self,
+        cache_key: &str,
+        raw_output: &[String],
+        theme: &Theme,
+    ) -> Vec<Line<'static>>;
+}
+
+impl AgentOutputRenderExt for TuiState {
+    fn render_agent_output_lines(
+        &self,
+        cache_key: &str,
+        raw_output: &[String],
+        theme: &Theme,
+    ) -> Vec<Line<'static>> {
+        segment::cached_render(cache_key, raw_output, theme)
+            .styled_lines
+    }
+}
