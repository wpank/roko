+fn apply_workspace_wave_assignments(plans: &mut [PlanEntry]) {
+    let Ok(root) = std::env::current_dir() else {
+        return;
+    };
+    let derived = derive_plan_waves(&root, plans);
+    if derived.is_empty() {
+        return;
+    }
+
+    for plan in plans {
+        if let Some(wave) = derived.get(&plan.id).copied() {
+            plan.wave = Some(wave);
+        }
+    }
+}
+
+fn derive_plan_waves(root: &std::path::Path, plans: &[PlanEntry]) -> HashMap<String, usize> {
+    if plans.is_empty() {
+        return HashMap::new();
+    }
+
+    let plan_ids: HashSet<String> = plans.iter().map(|plan| plan.id.clone()).collect();
+    let mut deps_by_plan: HashMap<String, HashSet<String>> = HashMap::new();
+    let mut found_plan_deps = false;
+
+    for plan in plans {
+        let tasks_path = plans_dir(root).join(&plan.id).join("tasks.toml");
+        let Ok(tasks_file) = TasksFile::parse(&tasks_path) else {
+            continue;
+        };
+
+        let deps: HashSet<String> = tasks_file
+            .tasks
+            .iter()
+            .flat_map(|task| task.depends_on_plan.iter())
+            .map(|dep| dep.trim())
+            .filter(|dep| !dep.is_empty())
+            .filter(|dep| plan_ids.contains(*dep))
+            .map(ToOwned::to_owned)
+            .collect();
+
+        found_plan_deps |= !deps.is_empty();
+        if !deps.is_empty() {
+            deps_by_plan.insert(plan.id.clone(), deps);
+        }
+    }
+
+    if !found_plan_deps {
+        return HashMap::new();
+    }
+
+    let mut assigned: HashMap<String, usize> = HashMap::new();
+    let mut remaining: HashSet<String> = plan_ids;
+    let mut wave_idx = 0usize;
+
+    while !remaining.is_empty() {
+        let mut ready: Vec<String> = remaining
+            .iter()
+            .filter(|plan_id| {
+                deps_by_plan
+                    .get(*plan_id)
+                    .into_iter()
+                    .flatten()
+                    .all(|dep| !remaining.contains(dep) || assigned.contains_key(dep))
+            })
+            .cloned()
+            .collect();
+        ready.sort();
+
+        if ready.is_empty() {
+            let mut unresolved: Vec<String> = remaining.drain().collect();
+            unresolved.sort();
+            for plan_id in unresolved {
+                assigned.insert(plan_id, wave_idx);
+            }
+            break;
+        }
+
+        for plan_id in ready {
+            remaining.remove(&plan_id);
+            assigned.insert(plan_id, wave_idx);
+        }
+        wave_idx += 1;
+    }
+
+    assigned
+}
+
+fn clamp_selected_wave_idx(waves: &[Wave], selected_wave_idx: &mut usize) {
+    if waves.is_empty() {
+        *selected_wave_idx = 0;
+    } else if *selected_wave_idx >= waves.len() {
+        *selected_wave_idx = waves.len() - 1;
+    }
+}
