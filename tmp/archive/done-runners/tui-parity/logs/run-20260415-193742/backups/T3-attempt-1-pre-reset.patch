+    if area.width == 0 || area.height == 0 {
+        return;
+    }
+
+    let paragraph = Paragraph::new(Line::from(Span::raw(text.to_string())))
+        .style(style)
+        .wrap(Wrap { trim: true })
+        .alignment(alignment);
+    frame.render_widget(paragraph, area);
+}
