+/// Live row data for the parallel pool widget.
+///
+/// This is the preferred shape for callers that already have `AgentRow`-style
+/// data in hand.
+#[derive(Debug, Clone)]
+pub(crate) struct ParallelPoolRow {
+    pub(crate) id: String,
+    pub(crate) role: String,
+    pub(crate) model: String,
+    pub(crate) task: String,
+    pub(crate) progress_pct: f64,
+    pub(crate) tokens_used: u64,
+    pub(crate) context_limit: u64,
+    pub(crate) state: AgentRunState,
+}
+
+impl ParallelPoolRow {
+    /// Build a live row from `TuiState::agents`.
+    pub(crate) fn from_agent_row(agent: &AgentRow) -> Self {
+        Self {
+            id: agent.id.clone(),
+            role: agent.role.clone(),
+            model: agent.model.clone(),
+            task: agent.current_task.clone(),
+            progress_pct: if agent.context_limit == 0 {
+                0.0
+            } else {
+                (agent.input_tokens as f64 / agent.context_limit as f64).clamp(0.0, 1.0)
+            },
+            tokens_used: agent.input_tokens,
+            context_limit: agent.context_limit,
+            state: if agent.active {
+                AgentRunState::Active
+            } else {
+                match agent.status {
+                    crate::tui::state::AgentStatus::Done => AgentRunState::Done,
+                    crate::tui::state::AgentStatus::Failed => AgentRunState::Failed,
+                    _ => AgentRunState::Idle,
+                }
+            },
+        }
+    }
+
+    fn context_ratio(&self) -> f64 {
+        if self.context_limit == 0 {
+            0.0
+        } else {
+            (self.tokens_used as f64 / self.context_limit as f64).clamp(0.0, 1.0)
+        }
+    }
+
+    fn context_label(&self) -> String {
+        format!(
+            "{}k/{}k",
+            self.tokens_used / 1_000,
+            self.context_limit / 1_000
+        )
+    }
+}
