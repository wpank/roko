+    fn test_state(runtime: Arc<dyn CliRuntime>) -> Arc<AppState> {
+        let dir = tempdir().expect("create tempdir for template tests");
+        Arc::new(AppState::new(
+            dir.path().to_path_buf(),
+            runtime,
