+#[derive(Debug, Clone)]
+pub struct RingBuffer<T> {
+    items: Vec<T>,
+    cap: usize,
+}
+
+impl<T> RingBuffer<T> {
+    pub fn new(cap: usize) -> Self {
+        Self {
+            items: Vec::new(),
+            cap,
+        }
+    }
+
+    pub fn push(&mut self, item: T) {
+        if self.cap == 0 {
+            return;
+        }
+        if self.items.len() == self.cap {
+            self.items.remove(0);
+        }
+        self.items.push(item);
+    }
+
+    pub fn is_empty(&self) -> bool {
+        self.items.is_empty()
+    }
+
+    pub fn as_slice(&self) -> &[T] {
+        &self.items
+    }
+}
+
+impl<T> Default for RingBuffer<T> {
+    fn default() -> Self {
+        Self::new(0)
+    }
+}
+
+/// Live WS stream tail for a single agent.
+#[derive(Debug, Clone)]
+pub struct AgentStream {
+    /// Bounded recent stream chunks.
+    pub chunks: RingBuffer<String>,
+    /// Whether the WS sidecar is currently connected.
+    pub connected: bool,
+    /// When the most recent chunk was received.
+    pub last_chunk_at: Option<Instant>,
+}
+
+impl AgentStream {
+    fn new() -> Self {
+        Self {
+            chunks: RingBuffer::new(200),
+            connected: false,
+            last_chunk_at: None,
+        }
+    }
+
+    fn push_chunk(&mut self, chunk: String) {
+        self.chunks.push(chunk);
+        self.connected = true;
+        self.last_chunk_at = Some(Instant::now());
+    }
+
+    fn mark_connected(&mut self) {
+        self.connected = true;
+    }
+
+    fn mark_disconnected(&mut self) {
+        self.connected = false;
+    }
+}
+
+impl Default for AgentStream {
+    fn default() -> Self {
+        Self::new()
+    }
+}
