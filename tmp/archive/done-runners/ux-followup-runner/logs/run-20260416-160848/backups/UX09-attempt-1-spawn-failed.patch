+            while let Some(chunk) = client.try_recv() {
+                match chunk {
+                    StreamChunk::Text(text) => self.tui_state.push_agent_chunk(&agent_id, text),
+                    StreamChunk::Done { session } => {
+                        if let Some(session) = session {
+                            self.tui_state
