+fn episode_fingerprint_prompt(
+    prompt: Option<&str>,
+    plan_id: &str,
+    task_id: &str,
+    role: &str,
+    model: &str,
+) -> String {
+    prompt
+        .map(str::trim)
+        .filter(|text| !text.is_empty())
+        .map(str::to_owned)
+        .unwrap_or_else(|| format!("plan_id={plan_id}\ntask_id={task_id}\nrole={role}\nmodel={model}"))
+}
+
+fn episode_fingerprint_outcome(episode: &Episode, outcome: Option<&str>) -> String {
+    outcome
+        .map(str::trim)
+        .filter(|text| !text.is_empty())
+        .map(str::to_owned)
+        .unwrap_or_else(|| {
+            if episode.success {
+                "success".to_string()
+            } else {
+                episode
+                    .failure_reason
+                    .clone()
+                    .unwrap_or_else(|| "failure".to_string())
+            }
+        })
+}
+
+fn agent_output_text(result: &AgentResult) -> Option<&str> {
+    result.output.body.as_text().ok().map(str::trim)
+}
+
+fn stamp_episode_hdc_fingerprint(
+    episode: &mut Episode,
+    prompt: Option<&str>,
+    outcome: Option<&str>,
+    plan_id: &str,
+    task_id: &str,
+    role: &str,
+    model: &str,
+) {
+    let prompt = episode_fingerprint_prompt(prompt, plan_id, task_id, role, model);
+    let outcome = episode_fingerprint_outcome(episode, outcome);
+    episode.attach_hdc_fingerprint(&prompt, &outcome);
+}
