-//! Chain witness subsystem placeholder.
+//! Chain witness helpers for anchoring attestation hashes.
 //!
-//! This keeps the witness placeholder in the chain crate until the real
-//! chain-facing witness loop is implemented.
+//! The current chain abstraction is read-only (`ChainClient`), so this module
+//! lands the verification-facing half of the workflow now:
+//!
+//! - attestation witness hashes are computed deterministically
+//! - witness anchors are tracked per client/chain inside the process
+//! - verification also accepts matching on-chain logs/receipts when the client
+//!   can already observe them
+//!
+//! A later wallet-backed batch can replace the synthetic anchor recording with a
+//! real transaction submission path without changing call sites.
+
+use std::collections::HashMap;
+use std::sync::LazyLock;
+
+use parking_lot::Mutex;
+use roko_core::{Attestation, ContentHash};
+
+use crate::{ChainClient, ChainResult, LogEntry, TxHash};
+
+static WITNESS_REGISTRY: LazyLock<Mutex<HashMap<WitnessKey, WitnessRecord>>> =
+    LazyLock::new(|| Mutex::new(HashMap::new()));
 
-/// Placeholder chain witness engine.
