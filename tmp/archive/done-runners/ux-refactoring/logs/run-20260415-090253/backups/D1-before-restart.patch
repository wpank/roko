+    fn attestation_sign_and_verify_roundtrip() {
+        let engram = Engram::builder(Kind::Task)
+            .body(Body::text("verify me"))
+            .build();
+        let key = signing_key(7);
+
+        let attestation = sign(&engram, &key);
+
+        assert!(verify(&engram, &attestation));
+        assert_eq!(attestation.public_key.0, key.verifying_key().to_bytes());
+        assert!(attestation.chain_attestation.is_none());
+    }
+
+    #[test]
+    fn attestation_rejects_mismatched_engram() {
+        let original = Engram::builder(Kind::Task)
+            .body(Body::text("original"))
+            .build();
+        let tampered = Engram::builder(Kind::Task)
+            .body(Body::text("tampered"))
+            .build();
+        let attestation = sign(&original, &signing_key(3));
+
+        assert!(!verify(&tampered, &attestation));
+    }
+
+    #[test]
+    fn witness_hash_ignores_chain_metadata() {
+        let engram = Engram::builder(Kind::Task)
+            .body(Body::text("same attestation"))
+            .build();
+        let mut attestation = sign(&engram, &signing_key(9));
+        let baseline = attestation.witness_hash();
+
+        attestation.chain_attestation = Some(ChainAttestation {
+            chain_id: 7,
+            tx_hash: [4; 32],
+            block_number: 11,
