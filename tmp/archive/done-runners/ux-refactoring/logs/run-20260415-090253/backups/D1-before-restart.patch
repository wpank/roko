+/// Placeholder-compatible witness engine wrapper.
 #[derive(Debug, Default, Clone, Copy, PartialEq, Eq)]
 pub struct ChainWitnessEngine;
 
 impl ChainWitnessEngine {
     /// Human-readable subsystem label.
