+    async fn witness_roundtrip_uses_client_scoped_registry() {
+        let client = MockChainClient::local().with_chain_id(11);
+        let attestation = attestation();
+
+        let tx_hash = witness_on_chain(&attestation, &client)
+            .await
+            .expect("record witness");
+
+        assert!(tx_hash.as_str().starts_with("0x"));
+        assert!(
+            verify_on_chain(&attestation, &client)
+                .await
+                .expect("verify witness")
+        );
+    }
+
+    #[tokio::test]
+    async fn verify_on_chain_accepts_matching_logs() {
+        let client = MockChainClient::local().with_chain_id(17);
+        let attestation = attestation();
+        let topic = witness_topic(&attestation);
+        client.insert_log(LogEntry {
+            address: "0x000000000000000000000000000000000000cafe".to_string(),
+            topics: vec![topic],
+            data: Vec::new(),
+        });
+
+        assert!(
+            verify_on_chain(&attestation, &client)
+                .await
+                .expect("verify witness from logs")
+        );
+    }
+
+    #[tokio::test]
+    async fn verify_on_chain_rejects_unwitnessed_attestation() {
+        let client = MockChainClient::local().with_chain_id(23);
+
+        assert!(
+            !verify_on_chain(&attestation(), &client)
+                .await
+                .expect("verify missing witness")
+        );
+    }
 }
