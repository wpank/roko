+    ) -> ChainResult<bool> {
+        verify_on_chain(attestation, chain_client).await
+    }
+}
+
+/// Record a synthetic witness anchor for an attestation on the current chain.
+pub async fn witness_on_chain(
+    attestation: &Attestation,
+    chain_client: &dyn ChainClient,
+) -> ChainResult<TxHash> {
+    let chain_id = chain_client.chain_id().await?;
+    let block_number = chain_client.block_number().await?;
+    let witness_hash = attestation.witness_hash();
+    let tx_hash = synthetic_tx_hash(chain_id, chain_client.name(), witness_hash);
+    let key = WitnessKey {
+        chain_id,
+        client_name: chain_client.name().to_string(),
+        witness_hash,
+    };
+    let record = WitnessRecord {
+        tx_hash: tx_hash.clone(),
+        block_number,
+    };
+    WITNESS_REGISTRY.lock().insert(key, record);
+    Ok(tx_hash)
+}
+
+/// Verify an attestation witness against both the in-process registry and any
+/// matching chain observations already available through `ChainClient`.
+pub async fn verify_on_chain(
+    attestation: &Attestation,
+    chain_client: &dyn ChainClient,
+) -> ChainResult<bool> {
+    let chain_id = chain_client.chain_id().await?;
+    let witness_hash = attestation.witness_hash();
+    let key = WitnessKey {
+        chain_id,
+        client_name: chain_client.name().to_string(),
+        witness_hash,
+    };
+
+    if WITNESS_REGISTRY.lock().contains_key(&key) {
+        return Ok(true);
+    }
+
+    if let Some(chain_attestation) = attestation.chain_attestation.as_ref() {
+        if chain_attestation.chain_id == chain_id {
+            let tx_hash = TxHash::new(hex_hash(chain_attestation.tx_hash));
+            if chain_client
+                .get_receipt(&tx_hash)
+                .await?
+                .is_some_and(|receipt| receipt.status)
+            {
+                return Ok(true);
+            }
+        }
+    }
+
+    let block_number = chain_client.block_number().await?;
+    let topic = witness_topic(attestation);
+    let expected_data = witness_hash.0.to_vec();
+    let logs = chain_client
+        .get_logs(0, block_number, &[], std::slice::from_ref(&topic))
+        .await?;
+    Ok(logs
+        .iter()
+        .any(|log| log_matches_witness(log, &topic, &expected_data)))
+}
+
+/// Canonical topic used when a chain backend exposes witness logs.
+#[must_use]
+pub fn witness_topic(attestation: &Attestation) -> String {
+    hex_hash(attestation.witness_hash().0)
+}
+
+fn synthetic_tx_hash(chain_id: u64, client_name: &str, witness_hash: ContentHash) -> TxHash {
+    let tx_hash = ContentHash::of(
+        format!("chain-witness:{chain_id}:{client_name}:{}", witness_hash.to_hex()).as_bytes(),
+    );
+    TxHash::new(hex_hash(tx_hash.0))
+}
+
+fn hex_hash(bytes: [u8; 32]) -> String {
+    format!("0x{}", ContentHash(bytes).to_hex())
+}
+
+fn log_matches_witness(log: &LogEntry, topic: &str, expected_data: &[u8]) -> bool {
+    log.topics
+        .iter()
+        .any(|candidate| candidate.eq_ignore_ascii_case(topic))
+        || log.data == expected_data
+}
+
