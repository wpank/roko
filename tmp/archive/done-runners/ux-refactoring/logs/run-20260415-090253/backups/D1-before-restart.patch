+    /// Evaluate whether a knowledge entry should move between retention tiers
+    /// based on recent gate verdicts and staleness.
+    #[must_use]
+    pub fn evaluate_promotion(
+        &self,
+        entry: &KnowledgeEntry,
+        verdicts: &[GateVerdict],
+    ) -> Option<KnowledgeTier> {
+        let successful_tasks = verdicts.iter().filter(|verdict| verdict.passed).count();
+        let failed_tasks = verdicts.iter().filter(|verdict| !verdict.passed).count();
+        let now = Utc::now();
+        let age_days = now
+            .signed_duration_since(entry.created_at)
+            .num_seconds()
+            .max(0) as f64
+            / 86_400.0;
+        let expiry_review = age_days >= entry.effective_half_life_days() * 2.0;
+
+        if failed_tasks >= 2 || expiry_review {
+            let next = previous_tier(entry.tier);
+            return (next != entry.tier).then_some(next);
+        }
+
+        if successful_tasks >= 3 {
+            let next = next_tier(entry.tier);
+            return (next != entry.tier).then_some(next);
+        }
+
+        None
+    }
