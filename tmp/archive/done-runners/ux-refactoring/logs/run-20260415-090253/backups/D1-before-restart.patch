+fn decode_attestation_signing_key(secret: &str) -> Option<SigningKey> {
+    let secret = secret.trim().trim_start_matches("0x");
+    if secret.len() != 64 {
+        return None;
+    }
+
+    let mut bytes = [0u8; 32];
+    for (idx, chunk) in secret.as_bytes().chunks_exact(2).enumerate() {
+        let hi = char::from(chunk[0]).to_digit(16)?;
+        let lo = char::from(chunk[1]).to_digit(16)?;
+        bytes[idx] = ((hi << 4) | lo) as u8;
+    }
+    Some(SigningKey::from_bytes(&bytes))
+}
+
+fn attestation_signing_key_from_env() -> Option<SigningKey> {
+    let secret = std::env::var(ATTESTATION_SIGNING_KEY_ENV).ok()?;
+    decode_attestation_signing_key(&secret)
+}
+
+fn maybe_attest_engram(mut signal: Engram) -> Engram {
+    let Some(key) = attestation_signing_key_from_env() else {
+        return signal;
+    };
+    signal.attestation = Some(sign_attestation(&signal, &key));
+    signal
 }
 
