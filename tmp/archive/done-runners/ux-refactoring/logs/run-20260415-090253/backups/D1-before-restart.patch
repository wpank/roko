+    /// Apply retention-tier updates in place and return the number of changed entries.
+    ///
+    /// # Errors
+    ///
+    /// Returns an error if the store cannot be read or rewritten.
+    pub fn update_tiers(&self, updates: &HashMap<String, KnowledgeTier>) -> Result<usize> {
+        if updates.is_empty() {
+            return Ok(0);
+        }
+
+        let _guard = self.write_gate.lock();
+        let mut entries = self.read_all()?;
+        let mut changed = 0usize;
+
+        for entry in &mut entries {
+            let Some(&tier) = updates.get(&entry.id) else {
+                continue;
+            };
+            if entry.tier == tier {
+                continue;
+            }
+            entry.tier = tier;
+            changed += 1;
+        }
+
+        if changed > 0 {
+            self.rewrite_all(&entries)?;
+        }
+
+        Ok(changed)
+    }
