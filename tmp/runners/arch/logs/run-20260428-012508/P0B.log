+    },
+    /// Run verification gates.
+    RunGates { run_id: String, config: GateConfig },
+    /// Create a git commit.
+    Commit {
+        run_id: String,
+        workdir: PathBuf,
+        message: String,
+    },
+    /// Persist a state checkpoint.
+    Checkpoint {
+        run_id: String,
+        state_json: String,
+        path: PathBuf,
+    },
+}
+
