+        let req = ModelCallRequest {
+            model: "claude-opus-4-20250514".into(),
+            system: None,
+            messages: vec![],
+            max_tokens: None,
+            temperature: None,
+            role: None,
+        };
+        assert_eq!(svc.resolve_model(&req), "claude-opus-4-20250514");
+    }
+}

