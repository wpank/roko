+            .build();
+        let ctx = Context::now().with_session(self.run_id.clone());
+        let result = agent.run(&prompt, &ctx).await;
+        let latency_ms = start.elapsed().as_millis() as u64;
+        let calculated_cost = self.cost_table.calculate(&model, &result.usage);
