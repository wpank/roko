+        Self {
+            data_dir,
+            buffer: Mutex::new(Vec::with_capacity(64)),
+            buffer_capacity: 64,
+        }
+    }
+
+    /// Create a service from the standard `.roko` directory.
+    #[must_use]
+    pub fn from_roko_dir(roko_dir: &Path) -> Self {
