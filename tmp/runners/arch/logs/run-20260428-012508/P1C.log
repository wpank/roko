+                FeedbackEvent::WorkflowComplete {
+                    run_id,
+                    outcome,
+                    total_cost_usd,
+                    total_tokens,
+                    duration_ms,
+                } => serde_json::json!({
+                    "kind": "workflow_complete",
+                    "run_id": run_id,
+                    "outcome": outcome,
+                    "total_cost_usd": total_cost_usd,
+                    "total_tokens": total_tokens,
