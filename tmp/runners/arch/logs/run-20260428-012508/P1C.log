        let event = match rx.recv().await {
            Ok(event) => event,
            Err(broadcast::error::RecvError::Lagged(skipped)) => {
                tracing::warn!(skipped, "learning subscriber lagged behind event stream");
                continue;
            }
            Err(broadcast::error::RecvError::Closed) => break,
        };

