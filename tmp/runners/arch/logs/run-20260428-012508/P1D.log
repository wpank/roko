fn summarize_lint_issues(stderr: &str, max: usize) -> String {
    let issues: Vec<&str> = stderr
        .lines()
        .filter(|l| {
            let t = l.trim_start();
            t.starts_with("warning:") || t.starts_with("error:") || t.starts_with("error[")
        })
        .take(max)
        .collect();
    if !issues.is_empty() {
        return issues.join("; ");
    }
    stderr
        .lines()

