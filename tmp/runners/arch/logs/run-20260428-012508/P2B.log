+                }
+
+                *status = TaskStatus::Skipped;
+
+                for (id, task) in &self.tasks {
+                    if task.depends_on.iter().any(|dep| dep == &skip_id) {
+                        to_skip.push_back(id.clone());
+                    }
+                }
+            }
+        }
+    }
