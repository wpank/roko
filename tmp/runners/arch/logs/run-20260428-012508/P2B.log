+                if all_deps_done {
+                    self.status.insert(id, TaskStatus::Ready);
+                }
+            }
+        }
+    }
+
+    fn skip_dependents(&mut self, failed_id: &str) {
+        let mut to_skip = VecDeque::new();
+
+        for (id, task) in &self.tasks {
+            if task.depends_on.iter().any(|dep| dep == failed_id) {
