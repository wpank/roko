pub enum MessageRole {
    /// System-authored message.
    System,
    /// User-authored message.
    User,
    /// Assistant-authored message.
    Assistant,
}

/// Response from a model call.
#[derive(Debug, Clone)]
pub struct ModelCallResponse {
    /// Complete model output.
    pub content: String,
    /// Resolved model identifier.
    pub model: String,
