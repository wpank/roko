pub type BoxFuture<'a, T> = Pin<Box<dyn Future<Output = T> + Send + 'a>>;

/// Request to call an LLM model.
#[derive(Debug, Clone)]
pub struct ModelCallRequest {
    /// Model identifier. An empty value lets the model service route by role.
    pub model: String,
