+        .unwrap_or_default()
+        .as_millis();
+    format!("run_{ts:x}")
+}
+
+fn truncate(s: &str, max: usize) -> &str {
+    if s.len() <= max {
+        s
+    } else {
+        &s[..s.floor_char_boundary(max)]
+    }
+}
+
