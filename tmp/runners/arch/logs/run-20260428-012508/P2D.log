        /// UTC timestamp.
        decided_at: chrono::DateTime<chrono::Utc>,
    },
}

/// Shared interior state backing both [`EventBus`] and [`BusSender`].
struct Shared<E> {
    tx: broadcast::Sender<Envelope<E>>,
    ring: Mutex<VecDeque<Envelope<E>>>,
    seq: AtomicU64,
    capacity: usize,
}

