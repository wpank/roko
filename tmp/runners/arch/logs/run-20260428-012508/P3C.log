    /// Collects all failure outputs for agent feedback.
    pub fn failure_summary(&self) -> String {
        self.verdicts
            .iter()
            .filter(|verdict| !verdict.passed)
            .map(|verdict| format!("{}: {}", verdict.gate_name, verdict.output))
            .collect::<Vec<_>>()
            .join("\n\n")
    }
}

