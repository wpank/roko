    for (gate_name, passed) in &verdict_summary {
        event_hub.publish(DashboardEvent::GateResult {
            plan_id: run_plan_id.clone(),
            task_id: prompt_text.chars().take(60).collect(),
            gate: gate_name.clone(),
            passed: *passed,
        });
    }

