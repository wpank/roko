            .tag("passed", verdict.passed.to_string())
            .tag("gate", &verdict.gate)
            .build();
        substrate
            .put(sig.clone())
            .await
            .map_err(|e| anyhow!("persist verdict: {e}"))?;
        verdict_summary.push((verdict.gate.clone(), verdict.passed));
        verdict_sigs.push(sig);
    }

