   654	                break;
   655	            }
   656	        }
   657	
   658	        let trimmed = line.trim();
   659	        if trimmed.is_empty() {
   660	            continue;
   661	        }
   662	
   663	        let event: ClaudeStreamEvent = match serde_json::from_str(trimmed) {
   664	            Ok(e) => e,
   665	            Err(_) => continue,
   666	        };
   667	
   668	        let cognitive_events = match event {
   669	            ClaudeStreamEvent::System(sys) => {
