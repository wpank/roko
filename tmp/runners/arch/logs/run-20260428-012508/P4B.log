   602	        Ok(child) => child,
   603	        Err(e) => {
   604	            error!(error = %e, "failed to spawn claude CLI");
   605	            let _ = event_sender
   606	                .send(CognitiveEvent::TokenChunk(format!(
   607	                    "Error: failed to spawn `claude` CLI: {e}"
   608	                )))
   609	                .await;
