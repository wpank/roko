   641	            biased;
   642	            _ = cancel_token.cancelled() => {
   643	                let _ = child.kill().await;
   644	                return Ok(());
   645	            }
   646	            result = reader.read_line(&mut line) => result,
   647	        };
   648	
   649	        match read_result {
   650	            Ok(0) => break, // EOF
   651	            Ok(_) => {}
   652	            Err(e) => {
