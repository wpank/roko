   740	        let mut stderr_reader = tokio::io::BufReader::new(stderr);
   741	        while let Ok(n) = stderr_reader.read_line(&mut stderr_buf).await {
   742	            if n == 0 {
   743	                break;
   744	            }
   745	        }
   746	        let stderr_trimmed = stderr_buf.trim();
   747	        if !stderr_trimmed.is_empty() {
   748	            warn!(session_id, stderr = %stderr_trimmed, "claude CLI stderr output");
   749	        }
   750	    }
   751	
   752	    // Wait for process to exit.
   753	    let status = child.wait().await;
   754	    debug!(session_id, ?status, cost = ?final_cost, "claude CLI process exited");
   755	
   756	    let stop_reason = StopReason::EndTurn;
   757	
   758	    let usage = if total_input > 0 || total_output > 0 {
   759	        Some(UsageInfo {
   760	            total_tokens: total_input + total_output,
   761	            input_tokens: total_input,
   762	            output_tokens: total_output,
   763	            thought_tokens: None,
   764	            cached_read_tokens: if total_cache_read > 0 {
   765	                Some(total_cache_read)
   766	            } else {
   767	                None
   768	            },
   769	            cached_write_tokens: if total_cache_write > 0 {
   770	                Some(total_cache_write)
   771	            } else {
   772	                None
   773	            },
   774	        })
   775	    } else {
   776	        None
   777	    };
   778	
   779	    let _ = event_sender
   780	        .send(CognitiveEvent::Complete { stop_reason, usage })
   781	        .await;
   782	
   783	    Ok(())
   784	}

