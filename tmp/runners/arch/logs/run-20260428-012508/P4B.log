   684	                        }
   685	                        ClaudeContentBlock::ToolUse { id, name } => {
   686	                            events.push(CognitiveEvent::ToolCallStart {
   687	                                tool_call_id: id.clone(),
   688	                                title: name.clone(),
   689	                                kind: tool_name_to_kind(name),
   690	                            });
   691	                        }
   692	                        ClaudeContentBlock::Thinking { thinking } => {
   693	                            events.push(CognitiveEvent::ThinkingChunk(thinking.clone()));
   694	                        }
   695	                    }
   696	                }
   697	                if let Some(usage) = &asst.message.usage {
   698	                    total_input = total_input.max(usage.input_tokens);
   699	                    total_output = total_output.max(usage.output_tokens);
   700	                    total_cache_read = total_cache_read.max(usage.cache_read_input_tokens);
   701	                    total_cache_write = total_cache_write.max(usage.cache_creation_input_tokens);
   702	                }
   703	                events
   704	            }
   705	            ClaudeStreamEvent::Tool(tool) => {
   706	                let truncated = if tool.content.len() > 4096 {
   707	                    format!("{}... [truncated]", &tool.content[..4096])
   708	                } else {
   709	                    tool.content
   710	                };
   711	                vec![CognitiveEvent::ToolCallComplete {
   712	                    tool_call_id: tool.tool_use_id,
   713	                    status: ToolCallStatus::Completed,
   714	                    content: vec![ContentBlock::Text { text: truncated }],
   715	                }]
   716	            }
   717	            ClaudeStreamEvent::Result(res) => {
   718	                if let Some(usage) = &res.usage {
   719	                    total_input = total_input.max(usage.input_tokens);
   720	                    total_output = total_output.max(usage.output_tokens);
   721	                    total_cache_read = total_cache_read.max(usage.cache_read_input_tokens);
   722	                    total_cache_write = total_cache_write.max(usage.cache_creation_input_tokens);
   723	                }
   724	                final_cost = res.total_cost_usd;
   725	                Vec::new() // we'll emit Complete after the loop
   726	            }
   727	        };
   728	
   729	        for ce in cognitive_events {
   730	            if event_sender.send(ce).await.is_err() {
   731	                let _ = child.kill().await;
   732	                return Ok(());
   733	            }
   734	        }
   735	    }
   736	
   737	    // Drain stderr for diagnostics.
   738	    if let Some(stderr) = child.stderr.take() {
