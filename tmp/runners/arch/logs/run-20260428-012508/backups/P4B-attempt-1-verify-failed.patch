+struct RuntimeGateRunnerAdapter {
+    inner: Arc<dyn CoreGateRunner>,
+}
+
+impl RuntimeGateRunnerAdapter {
+    fn new(inner: Arc<dyn CoreGateRunner>) -> Self {
