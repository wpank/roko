+struct AcpFeedbackSink {
+    data_dir: PathBuf,
+}
+
+impl AcpFeedbackSink {
+    fn from_roko_dir(roko_dir: &Path) -> Self {
+        Self {
+            data_dir: roko_dir.join("learn"),
+        }
+    }
+}
+
+impl RuntimeFeedbackSink for AcpFeedbackSink {
+    fn record(&self, event: RuntimeFeedbackEvent) -> RuntimeBoxFuture<'_, RuntimeResult<()>> {
+        let data_dir = self.data_dir.clone();
+        Box::pin(async move {
+            tokio::fs::create_dir_all(&data_dir).await?;
+            let path = data_dir.join("efficiency.jsonl");
+            let mut file = tokio::fs::OpenOptions::new()
+                .create(true)
+                .append(true)
+                .open(path)
+                .await?;
+            let line = feedback_json(event).to_string();
+            file.write_all(line.as_bytes()).await?;
+            file.write_all(b"\n").await?;
+            Ok(())
+        })
+    }
+}
