     1	//! JsonlLogger -- persists RuntimeEvents to a JSONL file.
     2	//!
     3	//! Each event is serialized as a single JSON line with a timestamp, enabling
     4	//! replay and state reconstruction.
     5	
     6	use roko_core::RuntimeEvent;
     7	pub use roko_core::foundation::EventConsumer;
     8	use roko_core::runtime_event::RuntimeEventEnvelope;
     9	use std::io::Write;
    10	use std::path::{Path, PathBuf};
    11	use std::sync::Mutex;
    12	use std::sync::atomic::{AtomicU64, Ordering};
    13	
    14	/// Logger that writes RuntimeEvents as JSONL (one JSON object per line).
    15	pub struct JsonlLogger {
    16	    path: PathBuf,
    17	    seq: AtomicU64,
    18	    writer: Mutex<Option<std::io::BufWriter<std::fs::File>>>,
    19	}
    20	
    21	impl JsonlLogger {
    22	    /// Create a new JsonlLogger writing to the given path.
    23	    pub fn new(path: PathBuf) -> Self {
    24	        Self {
    25	            path,
    26	            seq: AtomicU64::new(0),
    27	            writer: Mutex::new(None),
    28	        }
    29	    }
    30	
    31	    /// Create from the standard .roko directory.
    32	    pub fn from_roko_dir(roko_dir: &Path) -> Self {
    33	        Self::new(roko_dir.join("runtime-events.jsonl"))
    34	    }
    35	
    36	    /// Path to the log file.
    37	    pub fn path(&self) -> &Path {
    38	        &self.path
    39	    }
    40	
    41	    fn ensure_writer(&self) -> std::io::Result<()> {
    42	        let mut writer = self
    43	            .writer
    44	            .lock()
    45	            .unwrap_or_else(std::sync::PoisonError::into_inner);
    46	        if writer.is_none() {
    47	            if let Some(parent) = self.path.parent() {
    48	                std::fs::create_dir_all(parent)?;
    49	            }
    50	
    51	            let file = std::fs::OpenOptions::new()
    52	                .create(true)
    53	                .append(true)
    54	                .open(&self.path)?;
    55	            *writer = Some(std::io::BufWriter::new(file));
    56	        }
    57	        drop(writer);
    58	
    59	        Ok(())
    60	    }
    61	
    62	    fn write_event(&self, event: &RuntimeEvent) -> std::io::Result<()> {
    63	        self.ensure_writer()?;
    64	
    65	        let envelope = RuntimeEventEnvelope::new(
    66	            event.run_id(),
    67	            self.seq.fetch_add(1, Ordering::Relaxed),
    68	            "jsonl_logger",
    69	            event.clone(),
    70	        );
    71	
    72	        let json = serde_json::to_string(&envelope)
    73	            .map_err(|err| std::io::Error::new(std::io::ErrorKind::InvalidData, err))?;
    74	
    75	        let mut writer = self
    76	            .writer
    77	            .lock()
    78	            .unwrap_or_else(std::sync::PoisonError::into_inner);
    79	        if let Some(ref mut w) = *writer {
    80	            writeln!(w, "{json}")?;
    81	            w.flush()?;
    82	        }
    83	
    84	        Ok(())
    85	    }
    86	}
    87	
    88	impl EventConsumer for JsonlLogger {
    89	    fn consume(&self, event: &RuntimeEvent) {
    90	        let _ = self.write_event(event);
    91	    }
    92	}
