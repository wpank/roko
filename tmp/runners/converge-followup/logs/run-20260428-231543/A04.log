     1	//! RuntimeProjection -- reconstructs workflow state from JSONL event logs.
     2	//!
     3	//! Reads the JSONL file written by JsonlLogger and builds a snapshot of the
     4	//! current state for each run_id. Used for resume and dashboard views.
     5	
     6	use crate::effect_driver::Result;
     7	use roko_core::runtime_event::{RuntimeEvent, RuntimeEventEnvelope};
     8	use std::collections::HashMap;
     9	use std::path::Path;
    10	
    11	/// Summary of a workflow run reconstructed from events.
    12	#[derive(Debug, Clone, Default)]
    13	pub struct RunSummary {
    14	    /// Workflow run id.
    15	    pub run_id: String,
    16	    /// Workflow template label.
    17	    pub template: Option<String>,
    18	    /// Original user prompt.
    19	    pub prompt: Option<String>,
    20	    /// Current phase label.
    21	    pub current_phase: Option<String>,
    22	    /// Phase labels visited in event order.
    23	    pub phases_visited: Vec<String>,
    24	    /// Gate names that passed.
    25	    pub gates_passed: Vec<String>,
    26	    /// Gate names that failed.
    27	    pub gates_failed: Vec<String>,
    28	    /// Number of agent spawn events observed.
    29	    pub agents_spawned: u32,
    30	    /// Whether the workflow emitted a completion event.
    31	    pub is_complete: bool,
    32	    /// Final workflow outcome, when present.
    33	    pub outcome: Option<String>,
    34	    /// Number of completed agent turns observed.
    35	    pub agents_completed: u32,
    36	    /// Number of failed agent turns observed.
    37	    pub agents_failed: u32,
    38	    /// Cumulative tokens used across all agent calls (parsed from event log).
    39	    pub total_tokens: u64,
    40	    /// Cumulative cost in USD across all agent calls (parsed from event log).
    41	    pub total_cost_usd: f64,
    42	    /// Number of feedback_recorded events observed.
    43	    pub feedback_count: u32,
    44	    /// Last state checkpoint path recorded.
    45	    pub last_checkpoint: Option<String>,
    46	    /// Errors from agent_failed events.
    47	    pub agent_errors: Vec<String>,
    48	}
    49	
    50	/// Reads JSONL event logs and produces per-run summaries.
    51	pub struct RuntimeProjection;
    52	
    53	impl RuntimeProjection {
    54	    /// Read the event log and produce summaries for all runs.
    55	    pub fn from_file(path: &Path) -> Result<HashMap<String, RunSummary>> {
    56	        let mut runs: HashMap<String, RunSummary> = HashMap::new();
    57	
    58	        let content = match std::fs::read_to_string(path) {
    59	            Ok(content) => content,
    60	            Err(err) if err.kind() == std::io::ErrorKind::NotFound => return Ok(runs),
    61	            Err(err) => return Err(err.into()),
    62	        };
    63	
    64	        for line in content.lines() {
    65	            if line.trim().is_empty() {
    66	                continue;
    67	            }
    68	
    69	            let envelope: RuntimeEventEnvelope = match serde_json::from_str(line) {
    70	                Ok(envelope) => envelope,
    71	                Err(_) => continue,
    72	            };
    73	
    74	            let run_id = envelope.run_id.clone();
    75	            let summary = runs.entry(run_id.clone()).or_insert_with(|| RunSummary {
    76	                run_id: run_id.clone(),
    77	                ..Default::default()
    78	            });
    79	
    80	            apply_event(summary, &envelope.payload);
    81	        }
    82	
    83	        Ok(runs)
    84	    }
    85	
    86	    /// Get summary for a specific run.
    87	    pub fn for_run(path: &Path, run_id: &str) -> Result<Option<RunSummary>> {
    88	        let runs = Self::from_file(path)?;
    89	        Ok(runs.into_iter().find_map(
    90	            |(id, summary)| {
    91	                if id == run_id { Some(summary) } else { None }
    92	            },
    93	        ))
    94	    }
    95	}
    96	
    97	fn apply_event(summary: &mut RunSummary, event: &RuntimeEvent) {
    98	    match event {
    99	        RuntimeEvent::WorkflowStarted {
   100	            template, prompt, ..
   101	        } => {
   102	            summary.template = Some(template.clone());
   103	            summary.prompt = Some(prompt.clone());
   104	        }
   105	        RuntimeEvent::PhaseTransition { to, .. } => {
   106	            summary.current_phase = Some(to.clone());
   107	            summary.phases_visited.push(to.clone());
   108	        }
   109	        RuntimeEvent::GatePassed { gate_name, .. } => {
   110	            summary.gates_passed.push(gate_name.clone());
   111	        }
   112	        RuntimeEvent::GateFailed { gate_name, .. } => {
   113	            summary.gates_failed.push(gate_name.clone());
   114	        }
   115	        RuntimeEvent::AgentSpawned { .. } => {
   116	            summary.agents_spawned += 1;
   117	        }
   118	        RuntimeEvent::WorkflowCompleted { outcome, .. } => {
   119	            summary.is_complete = true;
   120	            summary.outcome = Some(outcome.to_string());
   121	        }
   122	        RuntimeEvent::AgentCompleted {
   123	            tokens_used,
   124	            cost_usd,
   125	            ..
   126	        } => {
   127	            summary.agents_completed += 1;
   128	            summary.total_tokens += tokens_used;
   129	            summary.total_cost_usd += cost_usd;
   130	        }
   131	        RuntimeEvent::AgentFailed { error, .. } => {
   132	            summary.agents_failed += 1;
   133	            summary.agent_errors.push(error.clone());
   134	        }
   135	        RuntimeEvent::FeedbackRecorded { .. } => {
   136	            summary.feedback_count += 1;
   137	        }
   138	        RuntimeEvent::StateCheckpointed { path, .. } => {
   139	            summary.last_checkpoint = Some(path.clone());
   140	        }
   141	        RuntimeEvent::AgentOutput { .. } => {
   142	            // AgentOutput is a streaming event; no aggregate RunSummary field yet.
   143	        }
   144	        RuntimeEvent::GateStarted { .. } => {
   145	            // GateStarted is informational; pass/fail events update gate summary fields.
   146	        }
   147	    }
   148	}
   149	
   150	#[cfg(test)]

