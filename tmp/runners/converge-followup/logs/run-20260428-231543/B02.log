enum WorkflowTomlScope {
    Root,
    Workflow,
    WorkflowStep,
    Other,
}

impl WorkflowConfig {
    /// Express: implement -> gate -> commit.
    pub fn express() -> Self {
        Self {
            has_strategy: false,
            has_review: false,
            max_iterations: 1,
            max_autofix_attempts: 1,
        }
    }

    /// Standard: implement -> gate -> review -> commit.
    pub fn standard() -> Self {
        Self {
            has_strategy: false,
