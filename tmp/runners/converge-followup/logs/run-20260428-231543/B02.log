+        where
+            'life0: 'async_trait,
+            Self: 'async_trait,
+        {
+            Box::pin(async { Ok(()) })
+        }
+    }
+
+    struct UnusedGateRunner;
+
+    impl GateRunner for UnusedGateRunner {
+        fn run_gates<'life0, 'async_trait>(
+            &'life0 self,
+            _config: GateConfig,
+        ) -> Pin<Box<dyn Future<Output = roko_core::Result<GateReport>> + Send + 'async_trait>>
+        where
+            'life0: 'async_trait,
