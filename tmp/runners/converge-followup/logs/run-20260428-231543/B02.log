impl PromptAssembler for AcpPromptAssembler {
    fn assemble<'life0, 'async_trait>(
        &'life0 self,
        spec: PromptSpec,
    ) -> Pin<Box<dyn Future<Output = roko_core::Result<String>> + Send + 'async_trait>>
    where
