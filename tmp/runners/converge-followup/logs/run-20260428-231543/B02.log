+                captured.lock().replace(req);
+                Ok(ModelCallResponse {
+                    content: "done".to_string(),
+                    model: "mock-model".to_string(),
+                    usage: TokenUsage {
+                        input_tokens: 10,
+                        output_tokens: 20,
+                        total_tokens: 30,
