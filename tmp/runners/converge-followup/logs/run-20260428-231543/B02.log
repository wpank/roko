+                })
+            })
+        }
+    }
+
+    struct ModulatingAffectPolicy;
+
+    impl AffectPolicy for ModulatingAffectPolicy {
+        fn pre_dispatch(&self, _task_id: &str, _role: &str) -> AffectContext {
+            AffectContext {
+                behavioral_state: BehavioralState::Exploring,
+                pad: [0.0, 0.3, 0.1],
