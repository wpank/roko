+
+    impl ModelCaller for RecordingModelCaller {
+        fn call<'life0, 'async_trait>(
+            &'life0 self,
+            req: ModelCallRequest,
+        ) -> Pin<Box<dyn Future<Output = roko_core::Result<ModelCallResponse>> + Send + 'async_trait>>
