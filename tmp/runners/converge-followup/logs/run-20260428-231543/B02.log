+        assert_eq!(request.cache_policy, CachePolicy::Bypass);
+        assert!(
+            request.temperature.is_some_and(|temperature| {
+                (temperature - 0.69).abs() < f32::EPSILON
+            }),
+            "expected modulated temperature, got {:?}",
+            request.temperature
