+                program,
+                args,
+                timeout_ms,
+            } => Some(CoreShellGateCommand {
+                program: program.clone(),
+                args: args.clone(),
+                timeout_ms: *timeout_ms,
+            }),
+            _ => None,
+        })
+        .collect()
