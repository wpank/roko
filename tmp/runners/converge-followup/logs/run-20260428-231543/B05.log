+            match tokio::fs::OpenOptions::new().read(true).open(path).await {
+                Ok(file) => file.sync_all().await?,
+                Err(err) if err.kind() == std::io::ErrorKind::NotFound => {}
+                Err(err) => return Err(err.into()),
+            }
+            Ok(())
+        })
+    }
