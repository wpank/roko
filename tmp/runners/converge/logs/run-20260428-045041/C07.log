diff --git a/crates/roko-core/src/lib.rs b/crates/roko-core/src/lib.rs
index 92d9d53dd233ab4a60eb69cecea4135ca356146e..e6ebd29b14bc95155bc046c8053db3b9c1fbf5f8
--- a/crates/roko-core/src/lib.rs
+++ b/crates/roko-core/src/lib.rs
@@ -46,6 +46,18 @@
     clippy::pedantic
 )]
 
+/// Generate a short share token: `<unix_millis_hex>-<rand_hex>`.
+pub fn generate_share_token() -> String {
+    use std::time::{SystemTime, UNIX_EPOCH};
+
+    let millis = SystemTime::now()
+        .duration_since(UNIX_EPOCH)
+        .unwrap_or_default()
+        .as_millis();
+    let rand_part: u16 = (millis as u16) ^ (std::process::id() as u16);
+    format!("{millis:x}-{rand_part:04x}")
+}
+
 pub mod affect;
 pub mod agent;
