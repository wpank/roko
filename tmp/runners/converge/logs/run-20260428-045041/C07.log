diff --git a/crates/roko-core/src/lib.rs b/crates/roko-core/src/lib.rs
index 92d9d53dd233ab4a60eb69cecea4135ca356146e..e6ebd29b14bc95155bc046c8053db3b9c1fbf5f8
--- a/crates/roko-core/src/lib.rs
