import './StatCard.css';

interface StatCardProps {
  label: string;
  value: string | number;
  sub?: string;
  color?: 'rose' | 'bone' | 'sage' | 'fail' | 'warn';
}

export default function StatCard({ label, value, sub, color = 'bone' }: StatCardProps) {
