+        <div style={emptyStyle}>Shared run not found</div>
+      </div>
+    );
+  }
+
+  const gateItems = report.gates.map(([name, passed]) => ({
+    name,
+    status: passed ? ('pass' as const) : ('fail' as const),
+  }));
+
+  return (
+    <div style={pageStyle}>
+      <div style={headerStyle}>
