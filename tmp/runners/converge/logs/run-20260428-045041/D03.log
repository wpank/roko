                    self.emit(RuntimeEvent::AgentSpawned {
                        run_id: run_id.clone(),
                        agent_id: String::new(),
                        role: "strategist".to_string(),
                        model: String::new(),
                    });
                    strategy_input(driver.spawn_agent("strategist", prompt, None).await)
                }
