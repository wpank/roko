+fn parse_workflow_config_toml(
+    s: &str,
+) -> Result<WorkflowConfigToml, Box<dyn std::error::Error + Send + Sync>> {
+    let mut workflow = WorkflowConfigToml {
+        template: None,
+        has_strategy: None,
+        has_review: None,
+        max_iterations: None,
+        max_autofix_attempts: None,
