+        sm.review_findings = vec!["needs error handling".into(), "add docs".into()];
+        sm.iteration = 2;
+        sm.phase = Phase::Implementing;
+
+        let json = sm.checkpoint().unwrap();
+        let restored = PipelineStateV2::from_checkpoint(&json).unwrap();
+
+        assert_eq!(
