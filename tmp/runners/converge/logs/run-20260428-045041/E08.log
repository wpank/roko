+fn commit_message_for(prompt: &str, prefix: Option<&str>) -> String {
+    let prompt = truncate(prompt, 60);
+    prefix.map_or_else(
         || format!("feat: {prompt}"),
         |prefix| format!("{prefix}: {prompt}"),
     )

