+        Phase::AutoFixing => PipelineOutput::SpawnAutoFixer {
+            error_output: pipeline.last_gate_failure.clone().unwrap_or_default(),
+        },
+        Phase::Reviewing => PipelineOutput::SpawnReviewer { diff_context: None },
