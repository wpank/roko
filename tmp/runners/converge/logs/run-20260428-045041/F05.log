    49	/// Reads JSONL event logs and produces per-run summaries.
    50	pub struct RuntimeProjection;
    51	
    52	impl RuntimeProjection {
    53	    /// Read the event log and produce summaries for all runs.
    54	    pub fn from_file(path: &Path) -> Result<HashMap<String, RunSummary>> {
    55	        let mut runs: HashMap<String, RunSummary> = HashMap::new();
    56	
    57	        let content = match std::fs::read_to_string(path) {
    58	            Ok(content) => content,
    59	            Err(err) if err.kind() == std::io::ErrorKind::NotFound => return Ok(runs),
    60	            Err(err) => return Err(err.into()),
    61	        };
    62	
    63	        for line in content.lines() {
    64	            if line.trim().is_empty() {
    65	                continue;
    66	            }
    67	
    68	            let value: serde_json::Value = match serde_json::from_str(line) {
    69	                Ok(value) => value,
    70	                Err(_) => continue,
    71	            };
    72	
    73	            let run_id = value["run_id"].as_str().unwrap_or("unknown").to_string();
    74	            let kind = value["kind"].as_str().unwrap_or_default();
    75	            let summary = runs.entry(run_id.clone()).or_insert_with(|| RunSummary {
    76	                run_id: run_id.clone(),
    77	                ..Default::default()
    78	            });
    79	
    80	            apply_event(summary, kind, &value);
    81	        }
    82	
    83	        Ok(runs)
    84	    }
    85	
    86	    /// Get summary for a specific run.
    87	    pub fn for_run(path: &Path, run_id: &str) -> Result<Option<RunSummary>> {
    88	        let runs = Self::from_file(path)?;
    89	        Ok(runs.into_iter().find_map(
    90	            |(id, summary)| {
    91	                if id == run_id {
    92	                    Some(summary)
    93	                } else {
    94	                    None
    95	                }
    96	            },
    97	        ))
    98	    }
    99	}
