    ///   `PermissionDenied`, `BudgetExceeded`, `BodyEncode`, `BodyDecode`,
    ///   `Json`, `Config`, `Planning`, `Verify`, `Tool`, `Cancelled` -- retry
    ///   will not succeed without caller intervention.
    #[must_use]
