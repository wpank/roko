+            self.cache_hits += 1;
+        }
+        if event.error.is_some() {
+            self.errors += 1;
+        }
+    }
+}
+
+fn gateway_events_path(workdir: &Path) -> PathBuf {
+    workdir.join(".roko").join("learn").join("gateway.jsonl")
+}
