+        writer
+            .write(&event("req-3", "cli", "model-a"))
+            .expect("write req-3");
+
+        let projection = GatewayProjection::load(&path).expect("load");
+        assert_eq!(projection.total_events(), 3);
+        assert_eq!(
+            projection.by_request_id("req-1").expect("req-1").caller,
