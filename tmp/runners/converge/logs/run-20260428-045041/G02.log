+    }
+
+    /// Total cost across all events.
+    #[must_use]
+    pub fn total_cost_usd(&self) -> f64 {
+        self.events.iter().map(|event| event.cost_usd).sum()
+    }
+
+    fn aggregate_by<'a>(
