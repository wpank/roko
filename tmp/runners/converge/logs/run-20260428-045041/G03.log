index 6ecf1ed620e7b00aa031846e2b09a90d717ee231..a7052751918f28537b9aa6aef17183814eabb91c
--- a/crates/roko-agent/src/model_call_service.rs
+++ b/crates/roko-agent/src/model_call_service.rs
