        if let Err(err) = self.save_snapshot().await {
            tracing::warn!(error = %err, "failed to save server state on shutdown");
        }
        self.cancel.cancel();
        self.supervisor.shutdown_all().await;
        self.event_bus.publish(ServerEvent::ServerShutdown);
