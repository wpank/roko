   673	// ---------------------------------------------------------------------------
   674	// Helpers
   675	// ---------------------------------------------------------------------------
   676	
   677	fn model_call_request(
   678	    model: String,
   679	    messages: &[ChatMessage],
   680	    max_tokens: Option<u32>,
   681	    temperature: Option<f64>,
   682	    role: Option<String>,
   683	) -> CoreModelCallRequest {
   684	    CoreModelCallRequest {
   685	        model,
   686	        system: None,
   687	        messages: messages.iter().map(core_chat_message).collect(),
   688	        max_tokens,
   689	        temperature: temperature.map(|t| t as f32),
   690	        role,
   691	        caller: Some(CallerIdentity::Serve),
   692	        budget: None,
   693	        cache_policy: CachePolicy::Default,
   694	    }
   695	}
   696	
   697	fn core_chat_message(message: &ChatMessage) -> CoreChatMessage {
   698	    CoreChatMessage {
   699	        role: match message.role.as_str() {
   700	            "system" => CoreMessageRole::System,
   701	            "assistant" => CoreMessageRole::Assistant,
   702	            _ => CoreMessageRole::User,
   703	        },
   704	        content: message.content.clone(),
   705	    }
   706	}
   707	
   708	fn completion_response_from_model_call(
   709	    id: String,
   710	    response: CoreModelCallResponse,
   711	) -> CompletionResponse {
   712	    let cost_usd = response.usage.cost_usd;
   713	    CompletionResponse {
   714	        id,
   715	        model: response.model,
   716	        content: response.content,
   717	        usage: TokenUsage {
   718	            input_tokens: response.usage.input_tokens,
   719	            output_tokens: response.usage.output_tokens,
   720	        },
   721	        stop_reason: response
   722	            .stop_reason
   723	            .unwrap_or_else(|| "end_turn".to_string()),
   724	        cost_usd,
   725	    }
   726	}
