+            "assistant" => CoreMessageRole::Assistant,
+            _ => CoreMessageRole::User,
+        },
+        content: message.content.clone(),
+    }
+}
+
+fn completion_response_from_model_call(
+    id: String,
+    response: CoreModelCallResponse,
