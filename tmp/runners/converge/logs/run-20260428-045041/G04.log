+fn model_call_request(
+    model: String,
+    messages: &[ChatMessage],
+    max_tokens: Option<u32>,
+    temperature: Option<f64>,
+    role: Option<String>,
+) -> CoreModelCallRequest {
+    CoreModelCallRequest {
+        model,
+        system: None,
+        messages: messages.iter().map(core_chat_message).collect(),
+        max_tokens,
+        temperature: temperature.map(|t| t as f32),
