   337	/// `GET /api/gateway/stats` — aggregate gateway statistics from provider
   338	/// health and latency registries.
   339	async fn gateway_stats(State(state): State<Arc<AppState>>) -> Json<GatewayStatsResponse> {
   340	    let health_snapshot = state.provider_health.snapshot();
   341	
   342	    let mut total_requests: u64 = 0;
   343	    let mut total_successes: u64 = 0;
   344	    let mut providers_json = serde_json::Map::new();
   345	
   500	    let batch_id_for_task = batch_id.clone();
   501	    let requests = body.requests;
   502	
   503	    let handle = tokio::spawn(async move {
   504	        let config = state_for_task.load_roko_config();
   505	
   506	        // B2: process batch items concurrently with a bounded stream.
   507	        let results: Vec<BatchResultItem> = stream::iter(requests)
   508	            .map(|item| {
   509	                let state_ref = Arc::clone(&state_for_task);
   510	                let config_ref = Arc::clone(&config);
   511	                let progress_ref = Arc::clone(&progress);
   512	                async move {
   513	                    let model_slug = if let Some(ref requested) = item.model {
   514	                        let resolved = resolve_model(&config_ref, requested);
   515	                        resolved.slug
   516	                    } else {
   517	                        // Batch items do not carry per-item routing hints; use
   518	                        // defaults (same as previous hardcoded behaviour).
   519	                        select_model_via_router(&state_ref, &RoutingHints::default()).await
   520	                    };
   521	
   522	                    let req =
   523	                        model_call_request(model_slug.clone(), &item.messages, None, None, None);
   524	
   525	                    let result_item = match state_ref.model_call_service.call(req).await {
   526	                        Ok(model_response) => {
   527	                            state_ref.provider_health.record_success(&model_slug);
   528	                            let served_model = model_response.model.clone();
   529	                            let input_tokens = model_response.usage.input_tokens;
   530	                            let output_tokens = model_response.usage.output_tokens;
   531	                            let cost_usd = model_response.usage.cost_usd;
   532	
   533	                            // B1: accumulate per-model counters.
   534	                            let counters = state_ref.gateway_counters_for(&served_model).await;
   535	                            counters.record(input_tokens, output_tokens, cost_usd);
   536	
   537	                            BatchResultItem {
   538	                                custom_id: item.custom_id.clone(),
   539	                                success: true,
   540	                                response: Some(completion_response_from_model_call(
   541	                                    uuid::Uuid::new_v4().to_string(),
   542	                                    model_response,
   543	                                )),
   544	                                error: None,
   545	                            }
   546	                        }
   547	                        Err(err) => {
   548	                            state_ref.provider_health.record_failure(&model_slug);
   549	                            BatchResultItem {
   550	                                custom_id: item.custom_id.clone(),
   551	                                success: false,
   552	                                response: None,
   553	                                error: Some(err.to_string()),
   554	                            }
   555	                        }
   556	                    };
   557	
   558	                    // B3: increment progress counter after each item.
   559	                    progress_ref.completed.fetch_add(1, Ordering::Relaxed);
   560	
   561	                    result_item
   562	                }
   563	            })
   564	            .buffer_unordered(BATCH_CONCURRENCY)
   565	            .collect()
   670	    }
   671	}
