+                        AgentResult::ok(output).with_usage(usage)
+                    }
+                    Err(error) => {
+                        let output = input
+                            .derive(Kind::AgentOutput, Body::text(error.to_string()))
+                            .provenance(Provenance::agent(name))
+                            .build();
+                        AgentResult::fail(output)
+                    }
+                }
+            }
+        }
     }
 
