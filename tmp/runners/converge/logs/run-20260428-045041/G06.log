 impl Agent for DreamReviewAgent {
     async fn run(&self, input: &Engram, ctx: &RokoContext) -> AgentResult {
-        self.inner.run(input, ctx).await
+        match self {
+            Self::Agent { inner } => inner.run(input, ctx).await,
