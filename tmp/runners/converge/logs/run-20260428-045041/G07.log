+    fn evict(&self, key: u64) {
+        let mut entries = self.entries.lock().expect("cache entries mutex poisoned");
+        let mut order = self.order.lock().expect("cache order mutex poisoned");
+        entries.remove(&key);
+        order.retain(|existing| *existing != key);
+    }
