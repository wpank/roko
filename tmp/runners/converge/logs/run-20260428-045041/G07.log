+
+        if let Some(budget) = budget {
+            if let Some(max_cost_usd) = budget.max_cost_usd {
+                if max_cost_usd <= 0.0 {
+                    return Err(GatewayError::BudgetExceeded {
+                        detail: format!(
+                            "per-call max_cost_usd must be positive, got {max_cost_usd:.6}"
