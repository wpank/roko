+
+        let first = CacheCell::cache_key("model-a", &messages, None);
+        let second = CacheCell::cache_key("model-b", &messages, None);
+
+        assert_ne!(first, second);
+    }
+
+    #[test]
+    fn cache_key_differs_on_temperature() {
+        let messages = vec![ChatMessage {
