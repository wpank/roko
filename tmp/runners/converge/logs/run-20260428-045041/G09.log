        assert!(layer.is_some());
    }

    #[test]
    fn with_scoped_safety_layer_preserves_existing_scope() {
        let observed = with_safety_layer(Some(SafetyLayer::with_defaults()), || {
            with_scoped_safety_layer(current_safety_layer)
        });
