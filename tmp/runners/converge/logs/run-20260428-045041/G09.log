### AP-10: Never use `todo!()` in public APIs

```rust
// BAD
pub async fn stream(&self, req: ModelCallRequest) -> Result<ModelCallStream> {
    todo!()
}

// GOOD
pub async fn stream(&self, req: ModelCallRequest) -> Result<ModelCallStream> {
    let response = self.call(req).await?;
    Ok(ModelCallStream::from_complete(response))
}
