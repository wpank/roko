    # posts insights back via HTTP JSON-RPC.
    "apps/roko-chain-watcher",
    # Standalone MCP servers used by agents via --mcp-config.
    "crates/roko-mcp-stdio",
    "crates/roko-mcp-github",
    "crates/roko-mcp-slack",
    "crates/roko-mcp-scripts",
    "crates/roko-mcp-code",

    # Roko CLI: minimal user-facing binary that wires the universal loop
    # (prompt → compose → agent → gate → persist → policy) against a working
    # directory. Reads its agent/gate config from ./roko.toml.
    "crates/roko-cli",
    # HTTP server crate extracted from roko-cli's serve module.
    "crates/roko-serve",
    # Per-agent HTTP server extracted from the legacy mirage dashboard surface.
    "crates/roko-agent-server",
    # ACP server surface for editor integrations.
    "crates/roko-acp",

    # Conductor — reactive intelligence layer: watchers, circuit breaker, interventions.
    "crates/roko-conductor",

    # Learning subsystems — episodes, playbooks, skills, caches, pattern discovery.
    "crates/roko-learn",

    # Neuro subsystem — knowledge + memory.
    "crates/roko-neuro",

    "crates/roko-dreams",
    # Daimon subsystem — affect and motivation modeling.
    "crates/roko-daimon",

    # Demo environment orchestrator — deploys contracts from roko/contracts/,
    # seeds fixtures, spawns a clade of agents per declarative scenario manifest.
    "crates/roko-demo",

    # Language providers — trait impls for specific languages/build systems.
    "crates/roko-lang-rust",
    "crates/roko-lang-typescript",
    "crates/roko-lang-go",

    # Code intelligence — parsing, symbol graphs, PageRank, HDC fingerprints.
    "crates/roko-index",
]
default-members = [
    # Ordinary root builds target the main CLI plus the MCP servers we ship.
    "crates/roko-cli",
    "crates/roko-mcp-code",
    "crates/roko-mcp-github",
]

