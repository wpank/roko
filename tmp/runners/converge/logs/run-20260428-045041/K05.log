+        for (knowledge_id, succeeded) in outcomes {
+            let delta = if *succeeded { 0.02 } else { -0.05 };
+            if self.update_confidence(knowledge_id, delta)? {
+                updated += 1;
+            }
+        }
+        Ok(updated)
+    }
