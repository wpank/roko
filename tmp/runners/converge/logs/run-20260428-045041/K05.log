            arousal: tags.iter().map(|t| t.pad.arousal).sum::<f64>() / n,
            dominance: tags.iter().map(|t| t.pad.dominance).sum::<f64>() / n,
        };

        Self {
            discovery_emotion: Self::coarse_emotion_label(tags[0].pad),
            average_pad: avg_pad,
            validation_arc: None,
            emotional_diversity: Self::compute_diversity(tags),
        }
    }
}

