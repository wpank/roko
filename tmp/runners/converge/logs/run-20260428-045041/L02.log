[workspace.package]
edition = "2024"
rust-version = "1.85"
license = "MIT OR Apache-2.0"
authors = ["Roko <engineering@roko.dev>"]
repository = "https://github.com/nunchi/roko"
homepage = "https://github.com/nunchi/roko"

# cargo-dist configuration for prebuilt binary releases.
# Targets: macOS ARM + Intel, Linux x86_64 glibc + musl.
[workspace.metadata.dist]
cargo-dist-version = "0.28.1"
ci = "github"
installers = ["shell"]
targets = [
    "aarch64-apple-darwin",
    "x86_64-apple-darwin",
    "x86_64-unknown-linux-gnu",
    "x86_64-unknown-linux-musl",
]
install-path = "CARGO_HOME"

[workspace.dependencies]
# Async runtime
tokio = { version = "1.50", features = ["full"] }
tokio-util = { version = "0.7", features = ["rt"] }

# Serialization
serde = { version = "1.0", features = ["derive"] }
serde_json = "1"
toml = "0.8"

# Error handling
thiserror = "2.0"
anyhow = "1.0"

# YAML (frontmatter parsing)
serde_yaml_ng = "0.10"

# Async trait dispatch
async-trait = "0.1"

# Logging / tracing
tracing = "0.1"
tracing-subscriber = { version = "0.3", features = ["env-filter", "json"] }

# Utilities
uuid = { version = "1", features = ["v4", "serde"] }
chrono = { version = "0.4", features = ["serde"] }
blake3 = "1"

# Testing & benchmarks
proptest = "1.10"
criterion = { version = "0.5", features = ["html_reports"] }
tempfile = "3"
assert_cmd = "2"
predicates = "3"


