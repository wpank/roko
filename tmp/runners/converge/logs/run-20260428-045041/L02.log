enum NeuroCmd {
    Query {
        topic: Vec<String>,
        workdir: Option<PathBuf>,
    },
    Stats {
        workdir: Option<PathBuf>,
    },
    Gc {
        workdir: Option<PathBuf>,
    },
    Backup {
        workdir: Option<PathBuf>,
        destination: PathBuf,
        force: bool,
        top_n: Option<usize>,
    },
