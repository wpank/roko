                    driver
                        .spawn_agent("reviewer", "Review the changes", diff_context.as_deref())
                        .await
                }),
                PipelineOutput::RunGates => {
                    self.emit(RuntimeEvent::GateStarted {
                        run_id: run_id.clone(),
                        gate_name: "pipeline".to_string(),
                        rung: 0,
                    });
                    driver.run_gates(&config.enabled_gates).await
                }
