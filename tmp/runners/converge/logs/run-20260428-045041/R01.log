}
pub trait EventConsumer: Send + Sync {
    fn consume(&self, event: &RuntimeEvent);
}
#[async_trait] pub trait EffectExecutor: Send + Sync {
    async fn execute(&self, effect: Effect) -> Result<EffectOutcome>;
}

impl GateReport {
