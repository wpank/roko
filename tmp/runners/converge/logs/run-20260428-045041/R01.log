# NOT in default features (no default key, or default doesn't include it)
! grep -q 'default.*legacy-orchestrate' crates/roko-cli/Cargo.toml

# Still compiles without the feature
cargo check -p roko-cli

# Still compiles with the feature
cargo check -p roko-cli --features legacy-orchestrate
```

