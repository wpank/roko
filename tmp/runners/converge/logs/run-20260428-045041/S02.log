   306	        // AgentOptions/provider adapters. The Anthropic and OpenAI-compatible
   307	        // adapters derive max tokens from ModelProfile::max_output and do not
   308	        // parse "max_tokens=..." or "temperature=..." extra_args.
   309	        // TODO(converge): Thread req-level MCP config here in S05 once
   310	        // ModelCallRequest carries it.
   311	
   312	        let agent =
   313	            create_agent_for_model(&config, &model, options).map_err(|err| RokoError::Agent {
   314	                backend: model.clone(),
   315	                message: err.to_string(),
   316	            })?;
   317	
   318	        let prompt = Engram::builder(Kind::Prompt)
   319	            .body(Body::text(user_content))
   320	            .build();
   321	        let ctx = Context::now().with_session(self.run_id.clone());
   322	        let result = agent.run(&prompt, &ctx).await;
   323	        let latency_ms = start.elapsed().as_millis() as u64;
   324	        let calculated_cost = self.cost_table.calculate(&model, &result.usage);
   325	        let cost_usd = if calculated_cost > 0.0 {
   326	            calculated_cost
   327	        } else {
   328	            f64::from(result.usage.cost_usd)
   329	        };
   330	        let usage = token_usage(&result.usage, cost_usd);
   331	
   332	        if !result.success {
   333	            let error = output_text(&result.output);
   334	            self.emit(RuntimeEvent::AgentFailed {
   335	                run_id: self.run_id.clone(),
   336	                agent_id,
   337	                error: error.clone(),
