   295	        let (message_system, user_content) = request_prompt(&req.messages);
   296	        let system_prompt = req.system.clone().or(message_system);
   297	        let config = self.config_for_model(&model);
   298	
   299	        let options = AgentOptions {
   300	            system_prompt,
   301	            name: req.role.clone().unwrap_or_else(|| "model_call".to_string()),
   302	            env: self.env.clone(),
   303	            ..AgentOptions::default()
   304	        };
