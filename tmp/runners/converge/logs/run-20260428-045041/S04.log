+            .map_or(0_u64, |system| system.chars().count() as u64)
+            + req
+                .messages
+                .iter()
+                .map(|message| message.content.chars().count() as u64)
+                .sum::<u64>();
+        let estimated_input_tokens = total_chars / 4;
+        let max_output_tokens = u64::from(req.max_tokens.unwrap_or(2048));
