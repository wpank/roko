        let svc = ModelCallService::new("default".into()).with_anthropic_api_key("sk-test".into());
        let req = ModelCallRequest {
            model: "claude-haiku-4".into(),
            system: None,
            messages: vec![],
            max_tokens: None,
            temperature: None,
            role: None,
        };
        let model = svc.resolve_model(&req);
        let config = svc.config_for_model(&model);

        let provider = config
            .providers
