+            .await
+            .unwrap();
+
+        assert!(prompt.contains("## Tool Instructions"));
+        assert!(prompt.contains("Use cargo check for Rust verification"));
+    }
+
+    #[test]
+    fn workspace_map_is_capped_to_two_hundred_lines() {
+        let listing = (0..250)
