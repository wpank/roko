+fn workspace_map_from_file_listing(file_listing: &[String]) -> Option<String> {
+    if file_listing.is_empty() {
+        return None;
+    }
+
+    let lines = file_listing
+        .iter()
+        .take(WORKSPACE_MAP_LINE_LIMIT)
+        .map(|path| format!("- {path}"))
+        .collect::<Vec<_>>()
+        .join("\n");
+
+    Some(format!("## Workspace Map\n{lines}"))
+}
