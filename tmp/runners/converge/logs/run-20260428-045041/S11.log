pub struct CascadeRouter {
    linucb: LinUCBRouter,
    confidence_stats: Mutex<HashMap<String, ModelStats>>,
    pareto_frontier: Mutex<ParetoFrontierState>,
    role_table: Mutex<HashMap<AgentRole, String>>,
