    episode.success = outcome == "success";
    episode.duration_secs = duration_ms as f64 / 1000.0;
    episode.tokens_used = total_tokens;
    episode.usage = Usage {
        cost_usd: total_cost_usd,
        cost_usd_without_cache: total_cost_usd,
        wall_ms: duration_ms,
        ..Usage::default()

