    /// -- -D warnings`. Callers that want a softer lint (warnings → warnings)
    /// can append their own args via the gate's `with_extra_args`.
    #[must_use]
    pub const fn lint_args(self) -> &'static [&'static str] {
        match self {
            Self::Cargo => &[
                "clippy",
                "--workspace",
                "--all-targets",
                "--",
                "-D",
                "warnings",
            ],
