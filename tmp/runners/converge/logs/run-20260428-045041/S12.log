+
+    fn cell_name(&self) -> &str {
+        "FormatCheckGate"
+    }
+
+    fn protocols(&self) -> &[&str] {
+        &["Verify"]
+    }
+}
+
+#[async_trait]
+impl Verify for FormatCheckGate {
+    async fn verify(&self, signal: &Engram, ctx: &Context) -> Verdict {
+        self.inner.verify(signal, ctx).await
+    }
+
+    fn name(&self) -> &str {
+        self.inner.name()
+    }
+}
