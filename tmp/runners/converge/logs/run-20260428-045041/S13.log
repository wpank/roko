   201	    async fn run_gates(&self, config: GateConfig) -> Result<GateReport> {
   202	        let payload = GatePayload::in_dir(config.workdir.clone());
   203	        let signal = Engram::builder(Kind::Task)
   204	            .body(Body::from_json(&payload)?)
   205	            .build();
   206	        let ctx = Context::now().with_attr("workdir", config.workdir.to_string_lossy());
   207	        let build_system = BuildSystem::detect(&config.workdir);
   208	
   209	        let mut verdicts = Vec::new();
   210	
   211	        for gate_name in Self::ordered_gate_names(&config) {
   212	            let rung = Self::rung_for_name(&gate_name);
   213	
   214	            if let Some(r) = rung {
   215	                if self.should_skip_rung_adaptively(Some(r))? {
   216	                    verdicts.push(GateVerdict {
   217	                        gate_name: gate_name.clone(),
   218	                        passed: true,
   219	                        output: format!("Skipped (adaptive: high pass rate for rung {r})"),
   220	                        duration_ms: 0,
   221	                    });
   222	                    continue;
   223	                }
   224	            }
   225	
   226	            let Some(gate) = self.gate_for_name(&gate_name, build_system) else {
   227	                verdicts.push(GateVerdict {
   228	                    gate_name: gate_name.clone(),
   229	                    passed: false,
   230	                    output: format!("Unknown gate: {gate_name}"),
   231	                    duration_ms: 0,
   232	                });
   233	                break;
   234	            };
   235	
   236	            let verdict = gate.verify(&signal, &ctx).await;
   237	            let passed = verdict.passed;
   238	            verdicts.push(to_gate_verdict(gate_name, verdict));
   239	
   240	            if let (Some(r), Some(adaptive)) = (rung, &self.adaptive)
