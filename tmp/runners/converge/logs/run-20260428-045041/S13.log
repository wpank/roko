   242	            {
   243	                thresholds.observe(u32::from(r), passed);
   244	            }
   245	
   246	            if !passed {
   247	                break;
   248	            }
   249	        }
   250	
   251	        Ok(GateReport { verdicts })
   252	    }
   253	}
