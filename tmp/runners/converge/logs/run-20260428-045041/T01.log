+                .any(|event| matches!(event, RuntimeEvent::PhaseTransition { .. }))
+        );
+        assert_eq!(
+            events
+                .iter()
+                .filter(|event| matches!(
+                    event,
+                    RuntimeEvent::WorkflowCompleted {
+                        outcome: roko_core::runtime_event::WorkflowOutcome::Success { .. },
+                        ..
+                    }
+                ))
+                .count(),
+            1
+        );
+    }
