/// A feedback event to record.
#[derive(Debug, Clone)]
pub enum FeedbackEvent {
    /// Feedback from a model call.
    ModelCall {
        run_id: String,
        model: String,
        role: String,
        input_tokens: u64,
        output_tokens: u64,
        cost_usd: f64,
        latency_ms: u64,
        success: bool,
    },
    /// Feedback from a gate execution.
    GateResult {
        run_id: String,
        gate_name: String,
