+
+        assert!(result.is_ok());
+        let result = result.unwrap();
+        assert!(matches!(result.outcome, WorkflowOutcome::Success { .. }));
+        assert_eq!(result.iterations, 1);
+        assert!(result.run_id.starts_with("run_"));
+    }
