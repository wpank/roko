+            workdir: isolated_git_workdir(),
+            workflow: WorkflowConfig::express(),
+            enabled_gates: Vec::new(),
+            commit_prefix: None,
+        }
+    }
+
+    fn isolated_git_workdir() -> PathBuf {
+        let tempdir = tempfile::tempdir().expect("create temp dir");
+        let workdir = tempdir.keep();
+
+        run_git(&workdir, &["init"]);
+        run_git(&workdir, &["config", "user.email", "test@example.com"]);
+        run_git(&workdir, &["config", "user.name", "Roko Test"]);
+
+        std::fs::write(workdir.join("change.txt"), "change\n").expect("write test change");
+        workdir
+    }
+
+    fn run_git(workdir: &std::path::Path, args: &[&str]) {
+        let output = Command::new("git")
+            .args(args)
+            .current_dir(workdir)
+            .output()
+            .expect("run git command");
+
+        assert!(
+            output.status.success(),
+            "git {:?} failed: {}",
+            args,
+            String::from_utf8_lossy(&output.stderr)
+        );
+    }
