// crates/roko-runtime/src/pipeline_state.rs (abridged)

#[derive(Debug, Clone)]   // <-- Clone is already derived
pub struct PipelineStateV2 {
    pub phase: Phase,
    pub config: WorkflowConfig,
    pub iteration: u32,
    pub autofix_attempts: u32,
