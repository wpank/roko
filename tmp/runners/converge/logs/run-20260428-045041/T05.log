fn unknown_share_returns_none() {
    let dir = tempfile::tempdir().unwrap();
    let shared_dir = dir.path().join(".roko").join("shared");
    std::fs::create_dir_all(&shared_dir).unwrap();

    // Try to load a transcript that doesn't exist
