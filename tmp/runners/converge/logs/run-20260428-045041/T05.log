    let data = std::fs::read_to_string(path);
    assert!(data.is_err());

    // Also verify with malformed JSON
    let bad_path = shared_dir.join("bad_run.json");
    std::fs::write(&bad_path, "not valid json").unwrap();
    let result: Result<RunTranscript, _> = serde_json::from_str(
        &std::fs::read_to_string(&bad_path).unwrap()
    );
    assert!(result.is_err());
}
