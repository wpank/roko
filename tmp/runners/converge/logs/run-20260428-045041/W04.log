+            Ok(result) => {
+                let success = matches!(
+                    &result.outcome,
+                    roko_runtime::workflow_engine::WorkflowOutcome::Success { .. }
+                );
+                let message = format!("{:?} in {} iterations", result.outcome, result.iterations);
