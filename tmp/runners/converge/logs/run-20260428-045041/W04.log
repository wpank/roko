+                let message = error.to_string();
+                println!("[{task_id}] failed: {message}");
+                tracing::warn!(task_id, error = %message, "v2 workflow task failed");
+                failed += 1;
+                outcomes.push((task_id.clone(), false, message));
+            }
+        }
+    }
+
+    Ok(PlanWorkflowReport {
+        total: tasks.len(),
+        passed,
+        failed,
+        outcomes,
