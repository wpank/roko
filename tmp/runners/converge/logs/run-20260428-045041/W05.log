                    .verdicts
                    .into_iter()
                    .map(|verdict| RuntimeGateVerdict {
                        gate_name: verdict.gate_name,
                        passed: verdict.passed,
                        output: verdict.output,
                        duration_ms: verdict.duration_ms,
                    })
                    .collect(),
            })

