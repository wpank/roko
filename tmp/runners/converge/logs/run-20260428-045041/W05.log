+    }
+
+    entries.push(PlanEntry {
+        content: "Commit changes".to_string(),
+        priority: Priority::Low,
+        status: plan_status(
+            phase,
+            &["committing"],
+            &[
+                "pending",
+                "strategizing",
+                "implementing",
+                "auto_fixing",
+                "gating",
+                "reviewing",
+            ],
+        ),
+    });
+
+    entries
+}
