+            }
+            CoreRuntimeEvent::WorkflowCompleted { run_id, outcome } => {
+                if self.accepts_run(run_id) {
+                    self.publish(CognitiveEvent::Complete {
+                        stop_reason: stop_reason_for_core_outcome(outcome),
+                        usage: None,
+                    });
+                }
