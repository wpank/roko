                model: String::new(),
                system: Some(system_prompt),
                messages: vec![ChatMessage {
                    role: MessageRole::User,
                    content: user_content,
                }],
                max_tokens: None,
                temperature: None,
                role: Some(role.to_string()),
            })
            .await;
        let latency_ms = duration_millis(start);

        match result {
