+        CoreWorkflowOutcome::Cancelled => StopReason::Cancelled,
+        CoreWorkflowOutcome::Success { .. } | CoreWorkflowOutcome::Halted { .. } => {
+            StopReason::EndTurn
+        }
     }
 }
 
