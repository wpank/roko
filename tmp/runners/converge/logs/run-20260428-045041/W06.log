            if let Some(advice) = &knowledge_advice {
                tracing::debug!(
                    has_signal = advice.has_signal,
                    hints = advice.hints.len(),
                    candidates = ?knowledge_candidates,
                    "knowledge routing advice produced"
                );
            } else {
                tracing::debug!(
                    candidates = ?knowledge_candidates,
                    "knowledge routing advice unavailable"
                );
            }
