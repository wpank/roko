+                agent_id: agent_id.clone(),
+                role: role.clone(),
+                model: dashboard_model_label(model, agent_id),
+            }],
+            RuntimeEvent::AgentOutput {
+                agent_id, chunk, ..
+            } => vec![DashboardEvent::AgentOutput {
+                agent_id: agent_id.clone(),
+                content: chunk.clone(),
+            }],
+            RuntimeEvent::GatePassed {
+                run_id,
+                gate_name,
+                duration_ms,
+            } => vec![workflow_gate_log_entry(
+                run_id,
+                gate_name,
+                *duration_ms,
+                true,
+            )],
+            RuntimeEvent::GateFailed {
+                run_id,
+                gate_name,
+                duration_ms,
+                ..
+            } => vec![workflow_gate_log_entry(
+                run_id,
+                gate_name,
+                *duration_ms,
+                false,
