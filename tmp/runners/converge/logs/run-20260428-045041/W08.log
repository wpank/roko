   166	/// Get the SseAdapter as an EventConsumer for WorkflowEngine registration.
   167	///
   168	/// Usage in routes/run.rs (future batch):
   169	/// ```ignore
   170	/// engine.add_consumer(crate::adapters::sse_event_consumer(&state.sse_adapter));
   171	/// ```
   172	#[must_use]
   173	pub fn sse_event_consumer(adapter: &Arc<SseAdapter>) -> Arc<dyn EventConsumer> {
   174	    Arc::clone(adapter) as Arc<dyn EventConsumer>
   175	}
   176	
   177	impl EventConsumer for SseAdapter {
   178	    fn consume(&self, event: &RuntimeEvent) {
   179	        let sse_event = Self::to_sse_event(event);
   180	        // Non-blocking: if no subscribers exist, the event is dropped.
   181	        let _ = self.sender.send(sse_event);
   182	    }
   183	}
