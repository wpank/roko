   156	/// `GET /api/workflow/events` — RuntimeEvent-typed SSE stream for WorkflowEngine.
   157	async fn workflow_sse_handler(
   158	    State(state): State<Arc<AppState>>,
   159	) -> Sse<impl Stream<Item = Result<Event, Infallible>>> {
   160	    let adapter: &Arc<SseAdapter> = &state.sse_adapter;
   161	    let rx = adapter.subscribe();
   162	    workflow_sse_from_adapter(rx)
   163	}
   164	
   165	fn workflow_sse_from_adapter(
   166	    rx: broadcast::Receiver<crate::adapters::SseEvent>,
   167	) -> Sse<impl Stream<Item = Result<Event, Infallible>>> {
   168	    let stream = stream::unfold(rx, |mut rx| async move {
   169	        loop {
   170	            match rx.recv().await {
   171	                Ok(sse_event) => {
   172	                    let data = serde_json::to_string(&sse_event).unwrap_or_default();
   173	                    let event = Event::default().event(sse_event.kind.clone()).data(data);
   174	                    return Some((Ok(event), rx));
   175	                }
   176	                Err(broadcast::error::RecvError::Lagged(n)) => {
   177	                    tracing::warn!(n, "workflow SSE client lagged");
   178	                    continue;
   179	                }
   180	                Err(broadcast::error::RecvError::Closed) => return None,
   181	            }
   182	        }
   183	    });
   184	
   185	    Sse::new(stream).keep_alive(KeepAlive::default())
   186	}

