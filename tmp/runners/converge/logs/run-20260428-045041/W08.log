   428	    /// Construct a new `AppState` from the working directory and loaded configs.
   429	    pub fn new(
   430	        workdir: PathBuf,
   431	        runtime: Arc<dyn CliRuntime>,
   432	        roko_config: RokoConfig,
   433	        deploy_backend: Arc<dyn DeployBackend>,
   434	    ) -> Self {
   435	        Self::new_with_daimon_strategy(
   436	            workdir,
   437	            runtime,
   438	            roko_config,
   439	            deploy_backend,
   440	            StrategySpaceDefinition::default(),
   441	        )
   442	    }
   443	
   444	    /// Construct a new `AppState` with an explicit Daimon strategy-space definition.
   445	    pub fn new_with_daimon_strategy(
   446	        workdir: PathBuf,
   447	        runtime: Arc<dyn CliRuntime>,
   448	        roko_config: RokoConfig,
   449	        deploy_backend: Arc<dyn DeployBackend>,
   450	        strategy_space: StrategySpaceDefinition,
   451	    ) -> Self {
   452	        let layout = RokoLayout::for_project(&workdir);
   453	        let layout_root = layout.root().to_path_buf();
   454	        let signal_root = layout_root.clone();
   455	        let affect_path = affect_state_path(&layout_root);
   456	        let cancel = CancelToken::new();
   457	        let supervisor = Arc::new(ProcessSupervisor::new(cancel.child()));
   458	        let subscriptions = SubscriptionRegistry::load_from_project(&workdir, &roko_config);
   459	        let mut affect_engine = DaimonState::load_or_new(&affect_path);
   460	        affect_engine.configure_strategy_space(strategy_space);
   461	
   462	        let mut template_registry = TemplateRegistry::new(workdir.clone());
   463	        template_registry.scan();
   464	
   465	        // Create StateHub with on-disk event log so all published events
   466	        // persist to `.roko/events.jsonl` for replay by standalone consumers.
   467	        let event_log_path = layout_root.join("events.jsonl");
   468	        let state_hub = roko_core::SharedStateHub::new(roko_core::StateHub::with_event_log(
   469	            1024,
   470	            &event_log_path,
   471	        ));
   472	
   473	        // Initialize chain client + wallet from [chain] config section.
   474	        let (chain_client, chain_wallet) = Self::init_chain(&roko_config);
   475	        let http_client = reqwest::Client::new();
   476	
   477	        Self {
   478	            workdir,
   479	            layout,
   480	            signal_store: SignalStore::new(signal_root),
   481	            cancel,
   482	            started_at: Instant::now(),
   483	            metrics: Arc::new(MetricRegistry::new()),
   484	            supervisor,
