+    #[test]
+    fn records_knowledge_usage_to_separate_log() {
+        let dir = tempfile::tempdir().unwrap();
+        let svc = FeedbackService::new(dir.path().to_path_buf());
+
+        svc.record_knowledge_usage(
+            "r1",
+            vec!["k1".to_string(), "k2".to_string()],
+            true,
+            "sonnet",
+        )
+        .unwrap();
+
+        let path = dir.path().join("knowledge-feedback.jsonl");
+        let content = std::fs::read_to_string(path).unwrap();
+        let record: serde_json::Value = serde_json::from_str(content.trim()).unwrap();
+
+        assert_eq!(
+            record.get("type").and_then(serde_json::Value::as_str),
+            Some("knowledge_usage")
+        );
+        assert_eq!(
+            record.get("run_id").and_then(serde_json::Value::as_str),
+            Some("r1")
+        );
+        assert_eq!(
+            record
+                .get("gate_passed")
+                .and_then(serde_json::Value::as_bool),
+            Some(true)
+        );
+        assert_eq!(
+            record.get("model_slug").and_then(serde_json::Value::as_str),
+            Some("sonnet")
+        );
+        assert!(
+            record
+                .get("timestamp")
+                .and_then(serde_json::Value::as_str)
+                .is_some()
+        );
+        assert!(!dir.path().join("efficiency.jsonl").exists());
+    }
